---
// src/components/Footer.astro
import {
  Phone,
  Mail,
  MapPin,
  MessageCircle,
  ArrowUpRight
} from "lucide-react";
---

<footer class="px-6 pt-20 pb-10 bg-zinc-950 text-white border-t border-white/10">
  <div class="max-w-7xl mx-auto">

    <!-- TOP -->
    <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-10 pb-14">

      <!-- BRAND -->
      <div class="xl:col-span-2">

        <div class="flex items-center gap-3 mb-5">
          <img
            src="/images/isotipo-avyna.png"
            alt="AVYNA"
            class="h-11 w-auto object-contain"
          />

          <div>
            <h3 class="text-2xl font-bold tracking-tight">
              AVYNA Saltillo
            </h3>

            <p class="text-sm text-white/45">
              Distribuidor Profesional
            </p>
          </div>
        </div>

        <p class="text-white/65 leading-relaxed max-w-xl">
          Distribución profesional de productos de belleza para salones,
          estilistas y emprendedores en Saltillo y alrededores.
          Atención directa, catálogo completo y seguimiento personalizado.
        </p>

        <a
          href="https://wa.me/528445069238?text=Hola,%20quiero%20informaci%C3%B3n%20de%20AVYNA"
          target="_blank"
          class="mt-6 inline-flex items-center gap-2 px-5 h-12 rounded-2xl bg-white text-black font-semibold hover:scale-[1.02] transition"
        >
          <MessageCircle size={17} />
          Solicitar Info
        </a>

      </div>

      <!-- NAV -->
      <div>
        <h4 class="font-semibold text-lg mb-5">
          Navegación
        </h4>

        <ul class="space-y-3 text-white/60">
          <li><a href="#nosotros" class="hover:text-white transition">Nosotros</a></li>
          <li><a href="#credito" class="hover:text-white transition">Crédito</a></li>
          <li><a href="#niveles" class="hover:text-white transition">Niveles</a></li>
          <li><a href="/catalogo" class="hover:text-white transition">Catálogo</a></li>
          <li><a href="#eventos" class="hover:text-white transition">Eventos</a></li>
          <li><a href="#contacto" class="hover:text-white transition">Contacto</a></li>
        </ul>
      </div>

      <!-- CONTACT -->
      <div>
        <h4 class="font-semibold text-lg mb-5">
          Contacto
        </h4>

        <ul class="space-y-4 text-white/60">

          <li class="flex items-start gap-3">
            <MapPin size={16} className="mt-1 shrink-0" />
            <span>Saltillo, Coahuila</span>
          </li>

          <li>
            <a
              href="tel:+528445069238"
              class="flex items-center gap-3 hover:text-white transition"
            >
              <Phone size={16} />
              844 506 9238
            </a>
          </li>

          <li>
            <a
              href="mailto:ayna.saltillo@gmail.com"
              class="flex items-center gap-3 hover:text-white transition break-all"
            >
              <Mail size={16} />
              avyna.saltillo@gmail.com
            </a>
          </li>

        </ul>
      </div>

    </div>

    <!-- BOTTOM -->
    <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row gap-4 justify-between items-start md:items-center text-sm text-white/40">

      <p>
        © 2026 AVYNA Saltillo. Todos los derechos reservados.
      </p>

      <a
        href="/catalogo"
        class="inline-flex items-center gap-2 hover:text-white transition"
      >
        Ver catálogo completo
        <ArrowUpRight size={15} />
      </a>

    </div>

  </div>
</footer>