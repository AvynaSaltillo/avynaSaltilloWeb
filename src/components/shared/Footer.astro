---
// src/components/shared/Footer.astro
import {
  Phone,
  Mail,
  MapPin,
  MessageCircle,
  ArrowUpRight,
  Store
} from "lucide-react";

import { FaInstagram } from "react-icons/fa";

import { TbLayoutDashboard } from "react-icons/tb";


const path = Astro.url.pathname;

const isGrow =
  path === "/grow" ||
  path === "/grow/" ||
  path.startsWith("/grow/");

const isCatalog =
  path === "/catalogo" ||
  path === "/catalogo/";

const isDiagnostico =
  path === "/diagnostico" ||
  path === "/diagnostico/";

const isInnerPage = isCatalog || isDiagnostico;

const linkTo = (id: string) => {
  if (isGrow) return `/grow#${id}`;
  if (isInnerPage) return `/#${id}`;
  return `#${id}`;
};

const navItems = isGrow
  ? [
      { label: "Nosotros", href: linkTo("nosotros") },
      { label: "Crédito", href: linkTo("credito") },
      { label: "Club Preferred", href: linkTo("clubPreferred") },
      { label: "Catálogo", href: "/grow/catalogo" },
    ]
  : [
      { label: "Marca", href: linkTo("nosotros") },
      { label: "Beneficios", href: linkTo("beneficios") },
      { label: "Catálogo", href: "/catalogo" },
      { label: "Diagnóstico", href: "/diagnostico" },
      { label: "Salones", href: linkTo("salones") },
      { label: "FAQ", href: linkTo("faq") },
    ];
---

<footer class="border-t border-white/20 bg-zinc-950 px-6 pt-10 pb-5 text-white">
  <div class="mx-auto max-w-7xl">

    <!-- TOP -->
    <div class="grid gap-10 pb-14 md:grid-cols-2 xl:grid-cols-5">

      <!-- BRAND -->
      <div class="xl:col-span-2">

        <div class="mb-5 flex items-center gap-3">
          <img
            src="/images/isotipo-avyna-white.png"
            alt="AVYNA"
            class="h-11 w-auto object-contain"
          />

          <div>
            <h3 class="text-2xl font-bold tracking-tight">
              AVYNA Saltillo
            </h3>

            <p class="text-sm text-white/45">
              {isGrow ? "Portal Profesional" : "Distribuidor Profesional"}
            </p>
          </div>
        </div>

        <p class="max-w-xl leading-relaxed text-white/65">
          {
            isGrow
              ? "Portal exclusivo para socios, salones y profesionales AVYNA."
              : "Distribución profesional de productos de belleza para salones, estilistas y emprendedores en Saltillo."
          }
        </p>

        <!-- ACTIONS -->
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">

          {
            !isGrow && (
              <a
                href="/grow/login"
                class="inline-flex h-12 items-center justify-center gap-2 rounded-2xl border border-white/10 bg-white px-5 font-semibold text-black transition hover:scale-[1.02]"
              >
                <Store size={22} />
                Tengo salón
              </a>
            )
          }

        </div>

      </div>

      <!-- NAV -->
      <div>
        <h4 class="mb-5 text-lg font-semibold">
          Navegación
        </h4>

        <ul class="space-y-3 text-white/60">
          {
            navItems.map((item) => (
              <li>
                <a href={item.href} class="transition hover:text-white">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- CONTACT -->
      <div>
        <h4 class="mb-5 text-lg font-semibold">
          Contacto
        </h4>

        <ul class="space-y-4 text-white/60">

          <li class="flex items-start gap-3">
            <MapPin size={20} className="mt-1 shrink-0" />
            <span>Saltillo, Coahuila</span>
          </li>

          <li>
            <a 
            href="https://instagram.com/avyna_distribucionsaltillo"
            class="flex items-center gap-3 break-all transition hover:text-white">
              <FaInstagram size={20} className="mt-1 shrink-0" />
              Avyna Distribución Saltillo
          </a> 
          </li> 

          <li>
            <a
              href="mailto:avyna.saltillo@gmail.com"
              class="flex items-center gap-3 break-all transition hover:text-white"
            >
              <Mail size={20} />
              avyna.saltillo@gmail.com
            </a>
          </li>

        </ul>
      </div>

            <!-- Socios -->
      <div>
        <h4 class="mb-5 text-lg font-semibold">
          Ya soy cliente
        </h4>

        <ul class="space-y-4 text-white/60">

          <li class="flex items-start gap-3">

            <a href="/portal/login"
            class="flex items-center gap-3 break-all transition hover:text-white">
              <TbLayoutDashboard size={20} className="mt-1 shrink-0" />
            <span>Ingresar al portal</span>
            
            </a>
            
            
          </li>
      
      </p>

        </ul>
      </div>

    </div>

   <!-- BOTTOM -->
<div class="flex flex-col gap-5 border-t border-white/10 pt-8 text-sm text-white/40 md:flex-row md:items-center md:justify-between">

  <!-- LEFT -->
  <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center">

    <p>
      © 2026 AVYNA Saltillo. Todos los derechos reservados.
    </p>

    <span class="hidden sm:block text-white/20">•</span>

    <a
      href="/privacy"
      class="transition hover:text-white"
    >
      Privacy Policy
    </a>

    <span class="hidden sm:block text-white/20">•</span>

    <a
      href="/terms"
      class="transition hover:text-white"
    >
      Terms & Conditions
    </a>

  </div>

  <!-- RIGHT -->
  {
    !isGrow && (
      <a
        href="/grow/login"
        class="inline-flex items-center gap-2 rounded-full border border-white/10 px-4 py-2 text-white transition hover:bg-white hover:text-black"
      >
        Quiero vender AVYNA
      </a>
    )
  }

</div>
    

  </div>
</footer>