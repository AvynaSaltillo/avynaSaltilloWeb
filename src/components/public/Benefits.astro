---
// src/components/public/Benefits.astro

import {
  Sparkles,
  ShieldCheck,
  Droplets,
  ScanSearch,
  ArrowRight,
  Star,
  BadgeCheck
} from "lucide-react";
---

<section class="relative overflow-hidden bg-black px-6 py-28 text-white">

  <!-- BACKGROUND -->
  <div class="pointer-events-none absolute inset-0">

    <div class="absolute left-0 top-0 h-96 w-96 rounded-full bg-white/5 blur-3xl glow-pulse"></div>

    <div class="absolute right-0 bottom-0 h-112 w-md rounded-full bg-zinc-300/5 blur-3xl"></div>

    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,.05),transparent_35%)]"></div>

  </div>

  <div class="relative z-10 mx-auto max-w-7xl">

    <!-- HEADER -->
    <div class="mx-auto max-w-4xl text-center">

      <div class="reveal inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-5 py-2 text-sm backdrop-blur-xl">
        <Sparkles size={16} />
        ¿Por qué elegir AVYNA?
      </div>

      <h2 class="reveal delay-1 mt-6 text-4xl font-bold leading-tight tracking-tight md:text-6xl">
        Resultados visibles,
        <span class="block text-zinc-400">
          experiencia profesional
        </span>
      </h2>

      <p class="reveal delay-2 mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-white/60">
        Cada línea AVYNA está diseñada para resolver necesidades reales:
        reparar, nutrir, proteger color, controlar frizz y elevar el brillo.
      </p>

    </div>

    <!-- GRID -->
    <div class="mt-16 grid gap-6 lg:grid-cols-3 items-stretch">

      <!-- CARD 1 -->
      <div class="p-6 xl:p-7 h-full flex flex-col reveal delay-1 hover-lift group rounded-4xl border border-white/10 bg-white/4backdrop-blur-2xl transition duration-500 hover:border-white/20 hover:bg-white/6r:shadow-[0_25px_60px_rgba(0,0,0,.45)]">

        <div class="flex items-center gap-4">

          <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white text-black shadow-xl">
            <Droplets size={24} />
          </div>

          <div>
            <p class="text-xs uppercase tracking-[0.28em] text-white/35">
              Nutrición
            </p>

            <h3 class="text-xl font-semibold">
              Hidratación profunda
            </h3>
          </div>

        </div>

        <p class="mt-6 leading-relaxed text-white/60">
          Fórmulas enfocadas en suavidad, elasticidad y nutrición visible
          desde las primeras aplicaciones.
        </p>

        <div class="mt-6 flex items-center gap-2 text-sm text-white/35">
          <BadgeCheck size={15} />
          Ideal para resequedad y opacidad
        </div>

      </div>

      <!-- CARD 2 -->
      <div class="p-6 xl:p-7 h-full flex flex-col reveal delay-2 hover-lift group rounded-4xl border border-white/10 bg-white/4backdrop-blur-2xl transition duration-500 hover:border-white/20 hoverhover:bg-white/6r:shadow-[0_25px_60px_rgba(0,0,0,.45)]">

        <div class="flex items-center gap-4">

          <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white text-black shadow-xl">
            <ShieldCheck size={24} />
          </div>

          <div>
            <p class="text-xs uppercase tracking-[0.28em] text-white/35">
              Repair
            </p>

            <h3 class="text-xl font-semibold">
              Reparación profesional
            </h3>
          </div>

        </div>

        <p class="mt-6 leading-relaxed text-white/60">
          Líneas especializadas para cabello maltratado por calor,
          decoloración, quiebre o procesos químicos.
        </p>

        <div class="mt-6 flex items-center gap-2 text-sm text-white/35">
          <BadgeCheck size={15} />
          Fortalece y mejora la hebra
        </div>

      </div>

      <!-- CARD 3 -->
      <div class="p-6 xl:p-7 h-full flex flex-col reveal delay-3 hover-lift group rounded-4xl border border-white/10 bg-white/4backdrop-blur-2xl transition duration-500 hover:border-white/20 hover:bg-white/6r:shadow-[0_25px_60px_rgba(0,0,0,.45)]">

        <div class="flex items-center gap-4">

          <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white text-black shadow-xl">
            <ScanSearch size={24} />
          </div>

          <div>
            <p class="text-xs uppercase tracking-[0.28em] text-white/35">
              Smart Care
            </p>

            <h3 class="text-xl font-semibold">
              Rutina personalizada
            </h3>
          </div>

        </div>

        <p class="mt-6 leading-relaxed text-white/60">
          No todos los cabellos necesitan lo mismo. Descubre la combinación
          ideal según tu tipo, historial y objetivos.
        </p>

        <a
          href="/diagnostico"
          class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-white transition hover:text-zinc-300"
        >
          Hacer diagnóstico
          <ArrowRight size={16} />
        </a>

      </div>

    </div>

    <!-- TRUST STRIP -->
    <div class="mt-14 grid gap-5 rounded-4xl border border-white/10 bg-white/3 p-6 backdrop-blur-xl md:grid-cols-3">

      <div class="reveal delay-1 hover-lift rounded-3xl bg-white/2 p-5">
        <div class="flex items-center gap-2 text-white/35">
          <Star size={15} />
          Ingredientes premium
        </div>

        <h4 class="mt-3 text-lg font-semibold">
          Hecho en Italia, calidad garantizada
        </h4>
      </div>

      <div class="reveal delay-2 hover-lift rounded-3xl bg-white/2 p-5">
        <div class="flex items-center gap-2 text-white/35">
          <Star size={15} />
          Compra segura
        </div>

        <h4 class="mt-3 text-lg font-semibold">
          Salones autorizados por AVYNA
        </h4>
      </div>

      <div class="reveal delay-3 hover-lift rounded-3xl bg-white/2 p-5">
        <div class="flex items-center gap-2 text-white/35">
          <Star size={15} />
          Asesoría real
        </div>

        <h4 class="mt-3 text-lg font-semibold">
          Diagnóstico IA + expertos AVYNA
        </h4>
      </div>

    </div>

  </div>

</section>