      ${100-report.frizz}%
    </p>
  </div>

</div>

<!-- GRID -->
<div class="mt-8 grid gap-6 lg:grid-cols-2">

  <div class="rounded-3xl border border-white/10 bg-white/4 p-6">
    <p class="text-xs uppercase tracking-[0.35em] text-white/35">
      Prioridades
    </p>

    <div class="mt-5 space-y-3">
      ${report.priorities.map(x => `
        <div class="text-white/75">• ${x}</div>
      `).join("")}
    </div>
  </div>

  <div class="rounded-3xl border border-white/10 bg-white/4 p-6">
    <p class="text-xs uppercase tracking-[0.35em] text-white/35">
      ¿Por qué estos productos?
    </p>

    <div class="mt-5 space-y-3">
      ${report.reasons.map(x => `
