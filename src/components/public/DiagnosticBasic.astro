document.querySelectorAll(".variantBtn").forEach(btn=>{

btn.onclick = ()=>{

const id = Number(btn.dataset.id);
const parent = btn.dataset.parent;

const product =
products.find(x=>x.id===id);

const card =
document.querySelector('[data-card="'+parent+'"]');

card.querySelector(".mainImg").src =
product.image;

card.querySelector(".family").innerHTML =
product.family;

card.querySelector(".desc").innerHTML =
product.description;

card.querySelector(".extra").innerHTML =
product.extra || "";

card.querySelectorAll(".variantBtn")
.forEach(x=>x.classList.remove("variantActive"));

btn.classList.add("variantActive");

};

});

document.getElementById("restartBtn").onclick = ()=>{
step = 0;
answers = {};
