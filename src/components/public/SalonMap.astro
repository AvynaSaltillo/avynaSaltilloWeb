---
// src/components/public/SalonMap.astro

import {
  MapPin,
  Search,
  Navigation,
  Phone,
  Star
} from "lucide-react";

import { salons } from "../../data/salons";


import Mapbox3DMap from "./MapBox3DMap.jsx";
---

<script define:vars={{ salons }}>
  window.AVYNA_SALONS = salons;
</script>

<section class="relative overflow-hidden bg-black px-6 py-28 text-white">

  <!-- BG -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute left-0 top-0 h-96 w-96 rounded-full bg-white/6 blur-3xl"></div>
    <div class="absolute right-0 bottom-0 h-112 w-md rounded-full bg-zinc-300/6 blur-3xl"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,.05),transparent_35%)]"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl">

    <!-- HEADER -->
    <div class="mx-auto max-w-4xl text-center">

      <div class="reveal inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-5 py-2 text-sm backdrop-blur-xl">
        <MapPin size={16} />
        Encuentra AVYNA cerca de ti
      </div>

      <h2 class="reveal delay-1 mt-6 text-4xl font-bold leading-tight tracking-tight md:text-6xl">
        Salones autorizados
        <span class="block text-zinc-400">
          en tu zona
        </span>
      </h2>

      <p class="reveal delay-2 mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-white/60">
        Busca por colonia, calle o nombre del salón y descubre
        dónde comprar productos AVYNA.
      </p>

    </div>

<!-- SEARCH -->
<div class="reveal delay-3 mx-auto mt-14 max-w-4xl">

  <div class="rounded-4xl border border-white/10 bg-white/4 p-3 backdrop-blur-2xl">

    <div class="flex flex-col gap-3 md:flex-row md:items-center">

      <!-- INPUT -->
      <div class="relative flex-1">

        <Search
          size={18}
          className="pointer-events-none absolute left-5 top-1/2 -translate-y-1/2 text-white/35"
        />

        <input
          id="salonSearch"
          type="text"
          placeholder="Buscar colonia, calle o salón..."
          class="h-14 w-full rounded-full border border-white/10 bg-black/30 pl-12 pr-5 text-white outline-none placeholder:text-white/30 transition focus:border-white/25"
        />

      </div>

      <!-- BUTTON -->
      <button
        id="nearMeBtn"
        type="button"
        class="inline-flex h-14 shrink-0 items-center justify-center gap-2 rounded-full border border-white/10 bg-white/6 px-6 text-sm font-medium transition hover:bg-white hover:text-black"
      >
        <MapPin size={16} />
        Cerca de mí
      </button>

    </div>

  </div>

</div>

    <!-- GRID -->
    <div class="mt-12 grid gap-8 lg:grid-cols-[1.05fr_.95fr]">

      <!-- MAP -->
      <div class="reveal-left rounded-4xl border border-white/10 bg-white/4 p-4 backdrop-blur-2xl">

        <div class="overflow-hidden rounded-[1.7rem] border border-white/10">
          <Mapbox3DMap salons={salons as any} client:only="react" />
        </div>

      </div>

      <!-- RIGHT SIDE -->
      <div class="space-y-4">

        <!-- LIST WRAPPER -->
        <div class="relative">

          <!-- LIST -->
          <div
            id="salonList"
            class="pl-2 pt-2 pb-2 max-h-138 w-full space-y-3 overflow-x-visible overflow-y-scroll pr-6"
          >

            {salons.map((salon, i) => (

              <div
                class={`salon-card delay-${(i % 4) + 1} hover-lift cursor-pointer rounded-4xl border border-white/10 bg-white/4 p-3 backdrop-blur-2xl transition`}
                data-search={`${salon.name} ${salon.address} ${salon.colony || ""}`.toLowerCase()}
                data-id={salon.id}
              >

                <div class="min-w-0">

                  {salon.featured && (
                    <div class="inline-flex items-center gap-2 rounded-full bg-white/5 px-3 py-1 text-[11px] text-white/55">
                      <Star size={11} />
                      Recomendado
                    </div>
                  )}

                  <h3 class="mt-2.5 text-base font-bold leading-tight">
                    {salon.name}
                  </h3>

                  <p class="mt-0.5 text-[13px] text-white/65">
                    {salon.address}, {salon.colony ? `${salon.colony}, ` : ""}{salon.city}
                  </p>

                  <p class="mt-3.5 text-[14px] leading-tight text-white/40">
                    {salon.horario}
                  </p>

                </div>

                <div class="mt-3 flex flex-wrap gap-2">

                  <button
                    class="inline-flex h-9 items-center gap-2 rounded-full bg-white px-4  text-sm font-semibold text-black"
                    onclick={`window.focusSalon(${salon.id})`}
                  >
                    <Navigation size={15} />
                    Ver mapa
                  </button>

                  {salon.phone && (
                    <a
                      href={`https://wa.me/${salon.phone}`}
                      target="_blank"
                      class="inline-flex h-9 items-center gap-2 rounded-full border border-white/10 px-4 text-sm"
                    >
                      <Phone size={15} />
                      Contactar
                    </a>
                  )}

                </div>

              </div>

            ))}

          </div>

          <!-- FADE SOLO SI HAY MÁS -->
          <div
            id="listFade"
            class="pointer-events-none absolute bottom-0 left-0 right-4 h-14  bg-linear-to-t from-black via-black/70 to-transparent opacity-100 transition duration-300"
          ></div>

        </div>

        <!-- LINEA DELGADA -->
        <div class="h-px bg-white/20"></div>

        <!-- NOTE -->
        <div class="delay-4 rounded-4xl border border-white/10 bg-white/4 p-5 backdrop-blur-xl">

          <p class="text-xs uppercase tracking-[0.28em] text-white/35">
            Recomendación
          </p>

          <p class="mt-3 text-sm leading-relaxed text-white/60">
            Para mejores resultados visita un salón autorizado.
            Un estilista puede evaluar tu cabello y sugerir
            la mejor rutina AVYNA.
          </p>

        </div>

      </div>

    </div>

  </div>

</section>

<script is:inline>
window.addEventListener("load", () => {

  const input = document.getElementById("salonSearch");
  const cards = [...document.querySelectorAll(".salon-card")];
  const list = document.getElementById("salonList");
  const fade = document.getElementById("listFade");
  const nearBtn = document.getElementById("nearMeBtn");

  /* ======================= */
  /* SEARCH */
  /* ======================= */

  input?.addEventListener("input", () => {

    const term =
      input.value.toLowerCase().trim();

    let firstVisible = null;

    cards.forEach((card) => {

      const text =
        card.dataset.search || "";

      const match =
        text.includes(term);

      card.style.display =
        match ? "block" : "none";

      if (match && !firstVisible) {
        firstVisible = card;
      }

    });

    if (firstVisible && term) {
      const id =
        Number(firstVisible.dataset.id);

      if (window.highlightSalon) {
        window.highlightSalon(id);
      }
    }

    setTimeout(updateFade, 50);
  });

  /* ======================= */
  /* CARD CLICK */
  /* ======================= */

  cards.forEach((card) => {

    card.addEventListener("click", (e) => {

      if (
        e.target.closest("button") ||
        e.target.closest("a")
      ) return;

      const id =
        Number(card.dataset.id);

      if (window.highlightSalon) {
        window.highlightSalon(id);
      }

    });

  });

  /* ======================= */
  /* CERCA DE MI */
  /* ======================= */

  nearBtn?.addEventListener("click", () => {

    if (!navigator.geolocation) return;

    nearBtn.innerHTML = "Buscando...";

    navigator.geolocation.getCurrentPosition(
      (pos) => {

        const userLat =
          pos.coords.latitude;

        const userLng =
          pos.coords.longitude;

        let nearest = null;
        let best = Infinity;

        cards.forEach((card) => {

          const id =
            Number(card.dataset.id);

          const salon =
            window.AVYNA_SALONS?.find(
              s => s.id === id
            );

          if (!salon) return;

          const dist =
            Math.hypot(
              salon.lat - userLat,
              salon.lng - userLng
            );

          if (dist < best) {
            best = dist;
            nearest = salon;
          }

        });

        if (nearest) {
          window.focusSalon(
            nearest.id
          );
        }

        nearBtn.innerHTML =
          "Cerca de mí";

      },
      () => {
        nearBtn.innerHTML =
          "Cerca de mí";
      }
    );

  });

  /* ======================= */
  /* FADE */
  /* ======================= */

  function updateFade() {

    if (!list || !fade) return;

    const hasMore =
      list.scrollTop +
        list.clientHeight <
      list.scrollHeight - 8;

    fade.style.opacity =
      hasMore ? "1" : "0";
  }

  updateFade();

  list?.addEventListener(
    "scroll",
    updateFade
  );

  window.addEventListener(
    "resize",
    updateFade
  );

});
</script>