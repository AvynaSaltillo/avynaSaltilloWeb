---
// src/components/Catalog.astro
import { products } from "../../data/products";
import {
  Search,
  ArrowUpRight,
  Sparkles,
  MessageCircle,
  Download,
  X,
  BadgeInfo,
  Package,
  Layers3,
  ShieldCheck,
  Star
} from "lucide-react";

const families = [
  "Todos",
  ...new Set(products.map((item) => item.family))
];
---

<section
  id="catalogo"
  class="min-h-screen overflow-hidden bg-black px-4 sm:px-6 pt-32 pb-24 text-white"
>
  <div class="mx-auto max-w-7xl">

    <!-- HERO -->
    <div class="mb-10 grid items-center gap-10 lg:grid-cols-2 lg:gap-16">

      <!-- LEFT -->
      <div>

        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm backdrop-blur-xl">
          <Sparkles size={15} className="shrink-0" />
          Catálogo Profesional
        </div>

        <h1 class="max-w-2xl text-4xl font-bold tracking-tight leading-[0.92] sm:text-5xl md:text-7xl">
          Línea completa
          <span class="block text-zinc-500">
            AVYNA
          </span>
        </h1>

        <p class="mt-6 max-w-xl text-base leading-relaxed text-white/65 md:text-lg">
          Productos italianos profesionales para salón, coloración,
          tratamientos premium y líneas especializadas.
        </p>

        <div class="mt-7 flex flex-wrap gap-x-5 gap-y-2 text-sm text-white/45">
          <span>✓ Distribuidor Saltillo</span>
          <span>✓ Atención directa</span>
          <span>✓ Pedido rápido</span>
        </div>

      </div>

      <!-- RIGHT -->
      <div class="space-y-4">

        <!-- SEARCH -->
        <div class="relative">

          <input
            id="searchInput"
            type="text"
            placeholder="Buscar producto..."
            class="h-14 w-full rounded-2xl border border-white/10 bg-white/5 pl-14 pr-5 outline-none transition placeholder:text-white/30 focus:border-white/25"
          />

          <Search
            size={18}
            className="pointer-events-none absolute left-5 top-1/2 -translate-y-1/2 text-white/35"
          />

        </div>

        <!-- ACTIONS -->
        <div class="grid grid-cols-2 gap-4">

          <a
            href="/catalogos/catalogo_avyna_2025.pdf"
            download
            class="flex h-12 items-center justify-center gap-2 rounded-2xl border border-white/10 bg-white/5 font-semibold transition hover:bg-white hover:text-black"
          >
            <Download size={16} />
            PDF
          </a>

        </div>

      </div>

    </div>

    <!-- FILTERS -->
    <div class="sticky top-20 z-20 mb-10">
      <div class="overflow-x-auto rounded-4xl border border-white/10 bg-white/5 p-3 backdrop-blur-xl no-scrollbar">
        <div class="flex min-w-max gap-3">

          {families.map((family, i) => (
            <button
              data-family={family}
              class={`family-btn h-11 whitespace-nowrap rounded-2xl px-6 text-sm font-semibold transition ${
                i === 0
                  ? "bg-white text-black"
                  : "border border-white/10 bg-white/5 hover:bg-white hover:text-black"
              }`}
            >
              {family}
            </button>
          ))}

        </div>
      </div>
    </div>

    <!-- GRID -->
    <!-- MOBILE = 2 CARDS -->
    <div
      id="catalogGrid"
      class="grid grid-cols-2 gap-3 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3 xl:grid-cols-4"
    >

      {products.map((item) => (
        <article
          class="product-card group relative cursor-pointer overflow-hidden rounded-3xl border border-white/10 bg-white/5 transition duration-500 hover:-translate-y-1 hover:border-white/20 hover:bg-white/10 hover:shadow-2xl"
          data-family={item.family}
          data-name={item.name.toLowerCase()}
          data-product={JSON.stringify(item)}
        >

          <!-- IMAGE -->
          <div class="relative aspect-square overflow-hidden bg-linear-to-br from-zinc-800 via-zinc-900 to-black">

            <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.10),transparent_55%)]"></div>

            <div class="absolute left-1/2 top-[46%] h-36 w-36 sm:h-52 sm:w-52 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white/10 blur-3xl"></div>

            <div class="absolute bottom-5 left-1/2 h-6 w-28 sm:w-36 -translate-x-1/2 rounded-full bg-black/70 blur-xl"></div>

            <img
              src={item.image}
              alt={item.name}
              loading="lazy"
              class="relative z-10 mx-auto mt-6 h-[72%] w-auto object-contain drop-shadow-[0_30px_35px_rgba(0,0,0,.60)] transition duration-700 group-hover:-translate-y-2 group-hover:scale-110"
            />

            {item.tag && (
              <span class="absolute top-3 left-3 z-20 rounded-full bg-white px-3 py-1 text-[10px] sm:text-xs font-semibold text-black shadow-xl">
                {item.tag}
              </span>
            )}

          </div>

          <!-- CONTENT -->
          <div class="p-4 sm:p-6">

            <p class="mb-2 text-[10px] sm:text-[11px] uppercase tracking-[0.25em] text-white/35">
              {item.family}
            </p>

            <h3 class="text-sm sm:text-xl font-semibold leading-snug line-clamp-2">
              {item.name}
            </h3>

            <p class="mt-1 text-xs sm:text-sm text-white/45 line-clamp-1">
              {item.type}
            </p>

            <div class="mt-3 flex items-center gap-2 text-[11px] sm:text-xs text-white/35">
              <BadgeInfo size={13} />
              Ver detalles
            </div>

            <button
              class="mt-4 sm:mt-6 flex h-10 sm:h-11 w-full items-center justify-center gap-2 rounded-2xl bg-white text-sm font-semibold text-black transition hover:scale-[1.02]"
            >
              Ver
              <ArrowUpRight size={15} />
            </button>

          </div>

        </article>
      ))}

    </div>

  </div>

  <!-- FLOAT WHATSAPP -->
  <a
    href="https://wa.me/528445069238"
    target="_blank"
    class="fixed right-4 bottom-4 z-50 hidden h-14 items-center gap-3 rounded-full bg-white px-6 font-semibold text-black shadow-2xl transition hover:scale-105 md:flex"
  >
    <MessageCircle size={18} />
    WhatsApp
  </a>

  <!-- MODAL -->
  <div
    id="productModal"
    class="fixed inset-0 z-999 hidden items-end justify-center bg-black/75 p-2 sm:p-4 backdrop-blur-md md:items-center overflow-y-auto"
  >

    <div
      id="modalBox"
      class="relative w-full max-w-md overflow-hidden rounded-4xl border border-white/10 bg-black text-white shadow-2xl max-h-[92vh] flex flex-col"
    >

      <div class="overflow-y-auto">

        <!-- IMAGE -->
        <div class="bg-zinc-900">
          <img
            id="modalImage"
            src=""
            alt=""
            class="h-52 sm:h-64 w-full object-contain"
          />
        </div>

        <!-- CONTENT -->
        <div class="relative p-5 sm:p-8">

          <button
            id="closeModal"
            class="absolute top-4 right-4 flex h-10 w-10 items-center justify-center rounded-full bg-white/5 transition hover:bg-white hover:text-black"
          >
            <X size={18} />
          </button>

          <p
            id="modalFamily"
            class="mb-3 text-xs uppercase tracking-[0.35em] text-white/35"
          ></p>

          <h3
            id="modalTitle"
            class="text-3xl sm:text-4xl font-bold leading-tight"
          ></h3>

          <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-white/70">
            <Layers3 size={15} />
            <span id="modalType"></span>
          </div>

          <!-- DESC -->
          <div class="mt-6 rounded-3xl border border-white/10 bg-white/5 p-5">
            <div class="mb-3 flex items-center gap-2 text-sm font-semibold">
              <Package size={16} />
              Descripción
            </div>

            <p
              id="modalDesc"
              class="text-sm leading-relaxed text-white/70"
            ></p>
          </div>

          <!-- EXTRA -->
          <div
            id="extraWrap"
            class="mt-4 rounded-3xl border border-white/10 bg-white/5 p-5 hidden"
          >
            <div class="mb-3 flex items-center gap-2 text-sm font-semibold">
              <ShieldCheck size={16} />
              Información Extra
            </div>

            <p
              id="modalExtra"
              class="text-sm leading-relaxed text-white/70"
            ></p>
          </div>

          <!-- BENEFITS -->
          <div class="mt-4 grid grid-cols-2 gap-3">

            <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-sm">
              <div class="mb-2 flex items-center gap-2 font-semibold">
                <Star size={15} />
                Calidad
              </div>
              Profesional
            </div>

            <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-sm">
              <div class="mb-2 flex items-center gap-2 font-semibold">
                <Sparkles size={15} />
                Línea
              </div>
              Premium
            </div>

          </div>

          <div class="mt-6 grid gap-3">

            <a
              id="modalWhatsapp"
              href="#"
              target="_blank"
              class="flex h-12 items-center justify-center rounded-2xl bg-white font-semibold text-black"
            >
              Solicitar por WhatsApp
            </a>

            <button
              id="closeBottom"
              class="h-12 rounded-2xl border border-white/10 transition hover:bg-white hover:text-black"
            >
              Cerrar
            </button>

          </div>

        </div>

      </div>

    </div>

  </div>

</section>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {

  const buttons = document.querySelectorAll(".family-btn");
  const cards = document.querySelectorAll(".product-card");
  const input = document.getElementById("searchInput");
  const modal = document.getElementById("productModal");

  let currentFamily = "Todos";

  function filterProducts() {
    const term = input?.value.toLowerCase().trim() || "";

    cards.forEach((card) => {
      const family = (card.dataset.family || "").toLowerCase();
      const name = (card.dataset.name || "").toLowerCase();

      const raw = card.dataset.product;
      let desc = "";
      let type = "";
      let extra = "";

      if (raw) {
        const data = JSON.parse(raw);
        desc = (data.description || "").toLowerCase();
        type = (data.type || "").toLowerCase();
        extra = (data.extra || "").toLowerCase();
      }

      const familyMatch =
        currentFamily === "Todos" ||
        card.dataset.family === currentFamily;

      const searchMatch =
        name.includes(term) ||
        family.includes(term) ||
        desc.includes(term) ||
        type.includes(term) ||
        extra.includes(term);

      card.style.display =
        familyMatch && searchMatch ? "block" : "none";
    });
  }

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      currentFamily = btn.dataset.family || "Todos";

      buttons.forEach((b) =>
        b.classList.remove("bg-white", "text-black")
      );

      btn.classList.add("bg-white", "text-black");

      filterProducts();
    });
  });

  input?.addEventListener("input", filterProducts);

  const title = document.getElementById("modalTitle");
  const familyText = document.getElementById("modalFamily");
  const type = document.getElementById("modalType");
  const desc = document.getElementById("modalDesc");
  const extra = document.getElementById("modalExtra");
  const extraWrap = document.getElementById("extraWrap");
  const image = document.getElementById("modalImage");
  const wa = document.getElementById("modalWhatsapp");

  cards.forEach((card) => {
    card.addEventListener("click", () => {

      const raw = card.dataset.product;
      if (!raw) return;

      const data = JSON.parse(raw);

      title.textContent = data.name || "";
      familyText.textContent = data.family || "";
      type.textContent = data.type || "";
      desc.textContent = data.description || "";

      if (data.extra?.trim()) {
        extra.textContent = data.extra;
        extraWrap.classList.remove("hidden");
      } else {
        extraWrap.classList.add("hidden");
      }

      image.src = data.image || "";
      image.alt = data.name || "";

      wa.href =
        "https://wa.me/528445069238?text=Hola,%20me%20interesa%20" +
        encodeURIComponent(data.name || "producto");

      modal.classList.remove("hidden");
      modal.classList.add("flex");

      document.body.style.overflow = "hidden";
    });
  });

  function closeModal() {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    document.body.style.overflow = "";
  }

  document.getElementById("closeModal")
    ?.addEventListener("click", closeModal);

  document.getElementById("closeBottom")
    ?.addEventListener("click", closeModal);

  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });

});
</script>