---
import {
  Crown,
  Sparkles,
  TrendingUp,
  Users,
  BadgeDollarSign,
  ArrowUpRight
} from "lucide-react";
---

<section
  class="
    group relative overflow-hidden

    rounded-[2.2rem]

    border border-white/10

    bg-gradient-to-br
    from-white/[0.07]
    via-white/[0.03]
    to-black

    p-6 sm:p-7
  "
>

  <!-- TOP LINE -->
  <div
    class="
      absolute left-0 top-0 h-px w-full

      bg-gradient-to-r
      from-white/50
      via-white/10
      to-transparent
    "
  ></div>

  <!-- GLOW -->
  <div
    class="
      absolute -right-16 top-0

      h-72 w-72

      rounded-full

      bg-white/[0.04]

      blur-3xl
    "
  ></div>

  <!-- HEADER -->
  <div class="relative z-10 flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">

    <!-- LEFT -->
    <div>

      <!-- BADGE -->
      <div
        class="
          inline-flex items-center gap-2

          rounded-full

          border border-yellow-500/15

          bg-yellow-500/10

          px-4 py-2

          text-[11px]
          uppercase
          tracking-[0.32em]

          text-yellow-300
        "
      >

        <Crown size={13} />

        Premium Accounts

      </div>

      <!-- TITLE -->
      <h3
        class="
          mt-5

          text-3xl
          font-semibold
          tracking-tight
        "
      >
        Top clientes
      </h3>

      <p class="mt-3 max-w-lg text-sm leading-7 text-white/45">
        Cuentas comerciales con mayor volumen de compras y actividad.
      </p>

    </div>

    <!-- RIGHT -->
    <div
      class="
        inline-flex items-center gap-2

        rounded-2xl

        border border-white/10

        bg-white/[0.04]

        px-4 py-3

        text-sm text-white/70
      "
    >

      <Sparkles
        size={15}
        className="text-yellow-300"
      />

      CRM Insights

    </div>

  </div>

  <!-- STATS -->
  <div
    class="
      relative z-10

      mt-8

      grid gap-3

      sm:grid-cols-3
    "
  >

    <!-- CLIENTS -->
    <div
      class="
        rounded-2xl

        border border-white/10

        bg-black/25

        p-4
      "
    >

      <p class="text-[10px] uppercase tracking-[0.28em] text-white/30">
        Clientes
      </p>

      <p class="mt-3 text-2xl font-semibold">
        24
      </p>

      <p class="mt-1 text-xs text-white/35">
        Cuentas activas
      </p>

    </div>

    <!-- REVENUE -->
    <div
      class="
        rounded-2xl

        border border-white/10

        bg-black/25

        p-4
      "
    >

      <p class="text-[10px] uppercase tracking-[0.28em] text-white/30">
        Revenue
      </p>

      <p class="mt-3 text-2xl font-semibold">
        Live
      </p>

      <p class="mt-1 text-xs text-emerald-300">
        Actividad comercial
      </p>

    </div>

    <!-- GROWTH -->
    <div
      class="
        rounded-2xl

        border border-white/10

        bg-black/25

        p-4
      "
    >

      <p class="text-[10px] uppercase tracking-[0.28em] text-white/30">
        Growth
      </p>

      <p class="mt-3 text-2xl font-semibold">
        +18%
      </p>

      <p class="mt-1 text-xs text-sky-300">
        Este periodo
      </p>

    </div>

  </div>

  <!-- LIST -->
  <div
    id="topClients"
    class="relative z-10 mt-8 space-y-4"
  >

    <!-- LOADING -->
    <div
      class="
        group/item relative overflow-hidden

        rounded-[1.75rem]

        border border-white/10

        bg-black/25

        p-5

        transition-all duration-300

        hover:border-white/20
        hover:bg-white/[0.03]
      "
    >

      <!-- GLOW -->
      <div
        class="
          absolute -right-8 -top-8

          h-28 w-28

          rounded-full

          bg-yellow-500/10

          blur-2xl
        "
      ></div>

      <div class="relative flex items-center gap-4">

        <!-- AVATAR -->
        <div
          class="
            grid h-14 w-14 shrink-0 place-items-center

            rounded-2xl

            border border-yellow-500/15

            bg-yellow-500/10

            text-lg
            font-semibold
            text-yellow-300
          "
        >
          A
        </div>

        <!-- INFO -->
        <div class="min-w-0 flex-1">

          <div class="flex items-start justify-between gap-4">

            <div class="min-w-0">

              <div class="flex flex-wrap items-center gap-2">

                <p class="truncate font-medium text-white">
                  Cargando clientes...
                </p>

                <span
                  class="
                    inline-flex items-center gap-1

                    rounded-full

                    border border-yellow-500/15

                    bg-yellow-500/10

                    px-2 py-1

                    text-[10px]
                    uppercase

                    text-yellow-300
                  "
                >

                  <Crown size={10} />

                  Premium

                </span>

              </div>

              <p class="mt-2 text-sm text-white/40">
                Analizando cuentas comerciales...
              </p>

            </div>

            <!-- AMOUNT -->
            <div class="text-right">

              <p class="text-xl font-semibold">
                $0.00
              </p>

              <p class="mt-1 text-xs text-emerald-300">
                Revenue
              </p>

            </div>

          </div>

          <!-- FOOT -->
          <div class="mt-4 flex flex-wrap items-center gap-2">

            <span
              class="
                inline-flex items-center gap-2

                rounded-full

                border border-white/10

                bg-white/[0.04]

                px-3 py-1

                text-[11px]

                text-white/50
              "
            >

              <Users size={11} />

              Cuenta activa

            </span>

            <span
              class="
                inline-flex items-center gap-2

                rounded-full

                border border-emerald-500/15

                bg-emerald-500/10

                px-3 py-1

                text-[11px]

                text-emerald-300
              "
            >

              <TrendingUp size={11} />

              +12%

            </span>

            <span
              class="
                inline-flex items-center gap-2

                rounded-full

                border border-sky-500/15

                bg-sky-500/10

                px-3 py-1

                text-[11px]

                text-sky-300
              "
            >

              <BadgeDollarSign size={11} />

              Top Account

            </span>

          </div>

        </div>

      </div>

    </div>

  </div>

</section>