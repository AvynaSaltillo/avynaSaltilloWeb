---
import {
  Activity,
  Sparkles,
  BellDot,
  ArrowUpRight
} from "lucide-react";
---

<section
  class="
    group relative overflow-hidden

    rounded-[2.2rem]

    border border-white/10

    bg-gradient-to-br
    from-white/[0.07]
    via-white/[0.03]
    to-black

    p-6 sm:p-7
  "
>

  <!-- TOP LINE -->
  <div
    class="
      absolute left-0 top-0 h-px w-full

      bg-gradient-to-r
      from-white/50
      via-white/10
      to-transparent
    "
  ></div>

  <!-- GLOWS -->
  <div
    class="
      absolute -right-20 top-0

      h-72 w-72

      rounded-full

      bg-white/[0.04]

      blur-3xl
    "
  ></div>

  <!-- HEADER -->
  <div class="relative z-10 flex items-start justify-between gap-4">

    <!-- LEFT -->
    <div>

      <!-- BADGE -->
      <div
        class="
          inline-flex items-center gap-2

          rounded-full

          border border-white/10

          bg-white/[0.04]

          px-4 py-2

          text-[11px]
          uppercase
          tracking-[0.32em]

          text-white/45
        "
      >

        <div
          class="
            h-2 w-2 rounded-full

            bg-emerald-400

            animate-pulse
          "
        ></div>

        Live Activity

      </div>

      <!-- TITLE -->
      <h3
        class="
          mt-5

          text-3xl
          font-semibold
          tracking-tight
        "
      >
        Actividad reciente
      </h3>

      <p class="mt-3 max-w-sm text-sm leading-7 text-white/45">
        Seguimiento operativo de pedidos, clientes y actividad comercial.
      </p>

    </div>

    <!-- ICON -->
    <div
      class="
        grid h-12 w-12 place-items-center

        rounded-2xl

        border border-white/10

        bg-white/[0.04]

        text-white/35
      "
    >

      <Activity size={20} />

    </div>

  </div>

  <!-- STATS -->
  <div class="relative z-10 mt-8 grid gap-3 sm:grid-cols-3">

    <!-- ORDERS -->
    <div
      class="
        rounded-2xl

        border border-white/10

        bg-black/25

        p-4
      "
    >

      <p class="text-[10px] uppercase tracking-[0.28em] text-white/30">
        Pedidos
      </p>

      <p class="mt-3 text-2xl font-semibold">
        12
      </p>

      <p class="mt-1 text-xs text-emerald-300">
        +4 hoy
      </p>

    </div>

    <!-- CLIENTS -->
    <div
      class="
        rounded-2xl

        border border-white/10

        bg-black/25

        p-4
      "
    >

      <p class="text-[10px] uppercase tracking-[0.28em] text-white/30">
        Clientes
      </p>

      <p class="mt-3 text-2xl font-semibold">
        3
      </p>

      <p class="mt-1 text-xs text-white/35">
        Nuevos registros
      </p>

    </div>

    <!-- ALERTS -->
    <div
      class="
        rounded-2xl

        border border-white/10

        bg-black/25

        p-4
      "
    >

      <p class="text-[10px] uppercase tracking-[0.28em] text-white/30">
        Alertas
      </p>

      <p class="mt-3 text-2xl font-semibold">
        2
      </p>

      <p class="mt-1 text-xs text-yellow-300">
        Requieren atención
      </p>

    </div>

  </div>

  <!-- FEED -->
  <div
    id="activityFeed"
    class="relative z-10 mt-8 space-y-4"
  >

    <!-- ITEM -->
    <div
      class="
        group/item

        relative overflow-hidden

        rounded-[1.75rem]

        border border-white/10

        bg-black/25

        p-5

        transition-all duration-300

        hover:border-white/20
        hover:bg-white/[0.03]
      "
    >

      <!-- LINE -->
      <div
        class="
          absolute left-6 top-0 bottom-0

          w-px

          bg-gradient-to-b
          from-emerald-400/50
          to-transparent
        "
      ></div>

      <div class="relative flex gap-4">

        <!-- ICON -->
        <div
          class="
            relative z-10

            mt-1

            grid h-10 w-10 shrink-0 place-items-center

            rounded-2xl

            border border-emerald-500/15

            bg-emerald-500/10

            text-emerald-300
          "
        >

          <Sparkles size={16} />

        </div>

        <!-- CONTENT -->
        <div class="min-w-0 flex-1">

          <div class="flex items-start justify-between gap-3">

            <div>

              <p class="font-medium text-white">
                Nuevo pedido registrado
              </p>

              <p class="mt-1 text-sm text-white/45">
                Cliente AVYNA realizó un pedido comercial.
              </p>

            </div>

            <span class="shrink-0 text-xs text-white/25">
              Hace 2 min
            </span>

          </div>

          <!-- FOOT -->
          <div class="mt-4 flex items-center gap-2">

            <span
              class="
                inline-flex items-center gap-2

                rounded-full

                border border-white/10

                bg-white/[0.04]

                px-3 py-1

                text-[11px]

                text-white/50
              "
            >

              <ArrowUpRight size={12} />

              Pedido #A51X92

            </span>

          </div>

        </div>

      </div>

    </div>

    <!-- ITEM -->
    <div
      class="
        rounded-[1.75rem]

        border border-white/10

        bg-black/25

        p-5
      "
    >

      <div class="flex gap-4">

        <!-- ICON -->
        <div
          class="
            mt-1

            grid h-10 w-10 shrink-0 place-items-center

            rounded-2xl

            border border-sky-500/15

            bg-sky-500/10

            text-sky-300
          "
        >

          <BellDot size={16} />

        </div>

        <!-- CONTENT -->
        <div class="min-w-0 flex-1">

          <div class="flex items-start justify-between gap-3">

            <div>

              <p class="font-medium text-white">
                Cliente aprobado
              </p>

              <p class="mt-1 text-sm text-white/45">
                Nuevo cliente activado correctamente.
              </p>

            </div>

            <span class="shrink-0 text-xs text-white/25">
              Hace 18 min
            </span>

          </div>

          <div class="mt-4">

            <span
              class="
                inline-flex rounded-full

                border border-sky-500/15

                bg-sky-500/10

                px-3 py-1

                text-[11px]

                text-sky-300
              "
            >
              Cliente activo
            </span>

          </div>

        </div>

      </div>

    </div>

    <!-- ITEM -->
    <div
      class="
        rounded-[1.75rem]

        border border-white/10

        bg-black/25

        p-5
      "
    >

      <div class="flex gap-4">

        <!-- ICON -->
        <div
          class="
            mt-1

            grid h-10 w-10 shrink-0 place-items-center

            rounded-2xl

            border border-yellow-500/15

            bg-yellow-500/10

            text-yellow-300
          "
        >

          <Activity size={16} />

        </div>

        <!-- CONTENT -->
        <div class="min-w-0 flex-1">

          <div class="flex items-start justify-between gap-3">

            <div>

              <p class="font-medium text-white">
                Pedido pendiente entrega
              </p>

              <p class="mt-1 text-sm text-white/45">
                Existen pedidos listos para coordinación.
              </p>

            </div>

            <span class="shrink-0 text-xs text-white/25">
              Hace 1 h
            </span>

          </div>

          <div class="mt-4">

            <span
              class="
                inline-flex rounded-full

                border border-yellow-500/15

                bg-yellow-500/10

                px-3 py-1

                text-[11px]

                text-yellow-300
              "
            >
              Requiere atención
            </span>

          </div>

        </div>

      </div>

    </div>

  </div>

</section>