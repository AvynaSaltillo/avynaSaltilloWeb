---
// src/components/admin/AdminTable.astro
---

<div class="table-wrap">

  <table class="admin-table text-left">

    <thead class="border-b border-white/10">

      <tr class="text-xs uppercase tracking-[0.35em] text-white/40">

        <th class="px-6 py-5">
          Pedido
        </th>

        <th class="px-6 py-5">
          Cliente
        </th>

        <th class="px-6 py-5">
          Estatus
        </th>

        <th class="px-6 py-5">
          Total
        </th>

        <th class="px-6 py-5">
          Fecha
        </th>

        <th class="px-6 py-5 text-right">
          Acción
        </th>

      </tr>

    </thead>

    <tbody id="ordersTable">

      <tr>

        <td
          colspan="6"
          class="py-16 text-center text-sm text-white/45"
        >
          Cargando pedidos...
        </td>

      </tr>

    </tbody>

  </table>

</div>