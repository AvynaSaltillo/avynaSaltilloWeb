---
// src/components/CreditInfo.astro
import {
  CreditCard,
  CalendarClock,
  Wallet,
  BadgePercent,
  CircleDollarSign,
  ShieldCheck,
  Sparkles
} from "lucide-react";
---

<section id="credito" class="bg-black px-6 py-24 text-white">
  <div class="mx-auto max-w-7xl">

    <!-- HEADER -->
    <div class="mb-16 grid items-center gap-14 lg:grid-cols-2">

      <!-- LEFT -->
      <div>

        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm backdrop-blur-xl">
          <CreditCard size={16} className="shrink-0" />
          Crédito de Compra
        </div>

        <h2 class="max-w-3xl text-4xl font-bold tracking-tight leading-tight md:text-6xl">
          Compra hoy, liquidez para crecer mañana
        </h2>

      </div>

      <!-- RIGHT -->
      <div>

        <p class="text-lg leading-relaxed text-white/65">
          Nuestro esquema comercial está pensado para salones y negocios
          profesionales que buscan surtirse sin descapitalizarse.
        </p>

        <p class="mt-5 text-lg leading-relaxed text-white/65">
          Facilitamos compras recurrentes, mejor flujo de efectivo y
          crecimiento ordenado con atención personalizada.
        </p>

        <p class="mt-5 text-lg leading-relaxed text-white/45">
          Crédito sujeto a continuidad comercial y cumplimiento.
        </p>

      </div>

    </div>

    <!-- GRID -->
    <div class="grid gap-8 lg:grid-cols-3">

      <!-- MAIN -->
      <div class="lg:col-span-2 rounded-[2.5rem] border border-white/10 bg-white/5 p-10 shadow-2xl backdrop-blur-2xl">

        <p class="mb-4 text-sm uppercase tracking-[0.25em] text-white/45">
          Esquema Principal
        </p>

        <h3 class="mb-8 text-3xl font-bold md:text-5xl">
          50% entrega + 50% a 15 días
        </h3>

        <div class="grid gap-6 md:grid-cols-2">

          <!-- CARD -->
          <div class="rounded-4xl border border-white/10 bg-white p-6 text-black shadow-xl">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-black text-white">
              <Wallet size={20} />
            </div>

            <h4 class="mb-2 text-lg font-semibold">
              50% Inicial
            </h4>

            <p class="text-zinc-600 leading-relaxed">
              Se abona al momento de entrega para confirmar operación.
            </p>
          </div>

          <!-- CARD -->
          <div class="rounded-4xl border border-white/10 bg-white/5 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-white text-black">
              <CalendarClock size={20} />
            </div>

            <h4 class="mb-2 text-lg font-semibold">
              15 Días Crédito
            </h4>

            <p class="leading-relaxed text-white/65">
              El restante 50% se cubre 15 días después de recibir el pedido.
            </p>
          </div>

        </div>

      </div>

      <!-- SIDE -->
      <div class="grid gap-6">

        <!-- CARD -->
        <div class="rounded-4xl border border-white/10 bg-white/5 p-7 transition hover:bg-white/10">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-white text-black">
            <CircleDollarSign size={20} />
          </div>

          <h4 class="mb-2 text-lg font-semibold">
            Pedido mínimo
          </h4>

          <p class="leading-relaxed text-white/65">
            Desde <strong class="text-white">$1,500 MXN</strong>
            por solicitud.
          </p>
        </div>

        <!-- CARD -->
        <div class="rounded-4xl border border-white/10 bg-white/5 p-7 transition hover:bg-white/10">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-white text-black">
            <BadgePercent size={20} />
          </div>

          <h4 class="mb-2 text-lg font-semibold">
            Beneficios Plus
          </h4>

          <p class="leading-relaxed text-white/65">
            Ventajas comerciales desde compras de
            <strong class="text-white"> $10,000 MXN</strong>.
          </p>
        </div>

        <!-- CARD -->
        <div class="rounded-4xl border border-white/10 bg-linear-to-br from-white/10 to-white/5 p-7">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-white text-black">
            <ShieldCheck size={20} />
          </div>

          <h4 class="mb-2 text-lg font-semibold">
            Confianza Mutua
          </h4>

          <p class="leading-relaxed text-white/65">
            Relación basada en cumplimiento, frecuencia y crecimiento conjunto.
          </p>

          <div class="mt-5 inline-flex items-center gap-2 text-sm text-white/45">
            <Sparkles size={15} />
            Atención personalizada
          </div>
        </div>

      </div>

    </div>

  </div>
</section>