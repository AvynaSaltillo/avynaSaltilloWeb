---
import "../styles/global.css";

const { title = "Portal AVYNA" } = Astro.props;
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
</head>

<body class="min-h-screen bg-black text-white antialiased">

  <!-- BACKGROUND -->
  <div class="fixed inset-0 -z-10 overflow-hidden">

    <div class="absolute inset-0 bg-black"></div>

    <div class="absolute left-[-10%] top-[-10%] h-[34rem] w-[34rem] rounded-full bg-white/[0.03] blur-3xl"></div>

    <div class="absolute bottom-[-10%] right-[-10%] h-[38rem] w-[38rem] rounded-full bg-white/[0.025] blur-3xl"></div>

    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.04),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(255,255,255,0.03),transparent_30%)]"></div>

  </div>

  <div class="flex min-h-screen">

    <!-- SIDEBAR -->
    <aside class="hidden w-76 shrink-0 border-r border-white/10 bg-white/[0.02] lg:block">

      <!-- sticky container -->
      <div class="sticky top-0 flex h-screen flex-col">

        <!-- TOP -->
        <div class="border-b border-white/10 px-6 pt-7 pb-6">

          <p class="text-[11px] uppercase tracking-[0.45em] text-white/30">
            AVYNA SALTILLO
          </p>

          <h1 class="mt-3 text-3xl font-semibold tracking-tight">
            Portal Privado
          </h1>

          <p class="mt-2 text-sm leading-6 text-white/45">
            Clientes activos, pedidos y atención comercial premium.
          </p>

        </div>

        <!-- NAV -->
        <nav class="flex-1 overflow-y-auto px-4 py-5 space-y-2 premium-scroll">

          <a
            href="/portal/dashboard"
            class="group flex items-center rounded-2xl px-4 py-3 text-sm font-medium text-white/75 transition hover:bg-white/10 hover:text-white"
          >
            Dashboard
          </a>

          <a
            href="/portal/profile"
            class="group flex items-center rounded-2xl px-4 py-3 text-sm font-medium text-white/75 transition hover:bg-white/10 hover:text-white"
          >
            Mi perfil
          </a>

          <a
            href="/portal/orders"
            class="group flex items-center rounded-2xl px-4 py-3 text-sm font-medium text-white/75 transition hover:bg-white/10 hover:text-white"
          >
            Pedidos
          </a>

          <a
            href="/grow"
            class="group flex items-center rounded-2xl px-4 py-3 text-sm font-medium text-white/75 transition hover:bg-white/10 hover:text-white"
          >
            Catálogo Grow
          </a>

          <a
            href="/portal/support"
            class="group flex items-center rounded-2xl px-4 py-3 text-sm font-medium text-white/75 transition hover:bg-white/10 hover:text-white"
          >
            Soporte
          </a>

        </nav>

        <!-- ALWAYS BOTTOM -->
        <div class="mt-auto border-t border-white/10 p-4">

          <div class="rounded-3xl border border-white/10 bg-black/50 p-4 backdrop-blur-xl">

            <p
              id="sidebarName"
              class="font-semibold"
            >
              Cliente
            </p>

            <p
              id="sidebarEmail"
              class="mt-1 break-all text-xs text-white/45"
            >
              cargando...
            </p>

            <button
              id="logoutBtn"
              class="mt-4 flex h-11 w-full items-center justify-center rounded-2xl bg-white font-semibold text-black transition hover:scale-[1.015]"
            >
              Cerrar sesión
            </button>

          </div>

        </div>

      </div>

    </aside>

    <!-- MAIN -->
    <div class="flex min-h-screen flex-1 flex-col">

      <!-- MOBILE TOPBAR -->
      <header class="sticky top-0 z-40 border-b border-white/10 bg-black/80 backdrop-blur-xl lg:hidden">

        <div class="flex items-center justify-between px-4 py-4">

          <div>
            <p class="text-[10px] uppercase tracking-[0.35em] text-white/35">
              AVYNA
            </p>

            <p class="text-sm font-semibold">
              Portal Privado
            </p>
          </div>

          <button
            id="mobileLogout"
            class="rounded-xl border border-white/10 px-4 py-2 text-sm text-white/80"
          >
            Salir
          </button>

        </div>

      </header>

      <!-- CONTENT -->
      <main class="flex-1 p-4 sm:p-6 lg:p-8">

        <div class="mx-auto max-w-7xl">
          <slot />
        </div>

      </main>

      <!-- FOOTER -->
      <footer class="border-t border-white/10 px-6 py-4 text-center text-xs text-white/25">
        © AVYNA Saltillo · Distribuidor autorizado
      </footer>

    </div>

  </div>

<script type="module">
import { supabase } from "/src/lib/supabase.ts";

async function boot() {

  const {
    data: { user }
  } = await supabase.auth.getUser();

  if (!user) {
    location.href = "/auth/login";
    return;
  }

  const { data: profile } = await supabase
    .from("profiles")
    .select("approved, role, first_name")
    .eq("id", user.id)
    .maybeSingle();

  if (!profile) {
    location.href = "/auth/signup";
    return;
  }

  if (profile.approved !== true) {
    location.href = "/auth/pending";
    return;
  }

  document.getElementById("sidebarName").textContent =
    profile.first_name || "Cliente";

  document.getElementById("sidebarEmail").textContent =
    user.email || "";

  markActive();
}

function markActive() {

  const path = window.location.pathname;

  document.querySelectorAll("aside nav a").forEach((link) => {

    const href = link.getAttribute("href");

    if (href && path.startsWith(href)) {

      link.classList.remove(
  "text-white/75",
  "hover:text-white"
);

link.classList.add(
  "bg-white",
  "!text-black",
  "font-semibold"
);

    }

  });
}

async function logout() {
  await supabase.auth.signOut();
  location.href = "/auth/login";
}

document
  .getElementById("logoutBtn")
  ?.addEventListener("click", logout);

document
  .getElementById("mobileLogout")
  ?.addEventListener("click", logout);

boot();
</script>

</body>
</html>