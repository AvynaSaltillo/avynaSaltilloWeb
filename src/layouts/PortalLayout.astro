---
import "../styles/global.css";

const { title = "Portal AVYNA" } = Astro.props;
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
</head>

<body class="min-h-screen bg-black text-white antialiased">

  <!-- BACKGROUND -->
  <div class="fixed inset-0 -z-10 overflow-hidden">

    <div class="absolute inset-0 bg-black"></div>

    <div class="absolute left-[-10%] top-[-10%] h-96 w-96 rounded-full bg-white/[0.03] blur-3xl"></div>

    <div class="absolute bottom-[-10%] right-[-10%] h-[30rem] w-[30rem] rounded-full bg-white/[0.03] blur-3xl"></div>

    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.04),transparent_30%),radial-gradient(circle_at_bottom_right,rgba(255,255,255,0.03),transparent_30%)]"></div>

  </div>

  <div class="flex min-h-screen">

    <!-- SIDEBAR -->
    <aside class="hidden w-72 border-r border-white/10 bg-white/[0.02] lg:flex lg:flex-col">

      <!-- BRAND -->
      <div class="border-b border-white/10 px-6 py-6">

        <p class="text-xs uppercase tracking-[0.4em] text-white/30">
          AVYNA SALTILLO
        </p>

        <h1 class="mt-3 text-2xl font-semibold tracking-tight">
          Portal Privado
        </h1>

        <p class="mt-2 text-sm text-white/45">
          Clientes activos y distribuición local.
        </p>

      </div>

      <!-- NAV -->
      <nav class="flex-1 space-y-2 px-4 py-5">

        <a
          href="/portal/dashboard"
          class="flex items-center rounded-2xl px-4 py-3 text-sm font-medium text-white/80 transition hover:bg-white/10 hover:text-white"
        >
          Dashboard
        </a>

        <a
          href="/portal/profile"
          class="flex items-center rounded-2xl px-4 py-3 text-sm font-medium text-white/80 transition hover:bg-white/10 hover:text-white"
        >
          Mi perfil
        </a>

        <a
          href="/portal/orders"
          class="flex items-center rounded-2xl px-4 py-3 text-sm font-medium text-white/80 transition hover:bg-white/10 hover:text-white"
        >
          Pedidos
        </a>

        <a
          href="/grow"
          class="flex items-center rounded-2xl px-4 py-3 text-sm font-medium text-white/80 transition hover:bg-white/10 hover:text-white"
        >
          Catálogo Grow
        </a>

        <a
          href="/portal/support"
          class="flex items-center rounded-2xl px-4 py-3 text-sm font-medium text-white/80 transition hover:bg-white/10 hover:text-white"
        >
          Soporte
        </a>

      </nav>

      <!-- USER -->
      <div class="border-t border-white/10 px-4 py-4">

        <div class="rounded-2xl border border-white/10 bg-black/40 p-4">

          <p
            id="sidebarName"
            class="font-medium"
          >
            Cliente
          </p>

          <p
            id="sidebarEmail"
            class="mt-1 text-xs text-white/45 break-all"
          >
            cargando...
          </p>

          <button
            id="logoutBtn"
            class="mt-4 flex h-10 w-full items-center justify-center rounded-xl bg-white font-medium text-black transition hover:scale-[1.01]"
          >
            Cerrar sesión
          </button>

        </div>

      </div>

    </aside>

    <!-- MAIN -->
    <div class="flex min-h-screen flex-1 flex-col">

      <!-- MOBILE TOPBAR -->
      <header class="sticky top-0 z-30 border-b border-white/10 bg-black/80 backdrop-blur-xl lg:hidden">

        <div class="flex items-center justify-between px-4 py-4">

          <div>
            <p class="text-[10px] uppercase tracking-[0.35em] text-white/35">
              AVYNA
            </p>

            <p class="text-sm font-medium">
              Portal Privado
            </p>
          </div>

          <button
            id="mobileLogout"
            class="rounded-xl border border-white/10 px-4 py-2 text-sm text-white/80"
          >
            Salir
          </button>

        </div>

      </header>

      <!-- CONTENT -->
      <main class="flex-1 p-4 sm:p-6 lg:p-8">

        <div class="mx-auto max-w-7xl">
          <slot />
        </div>

      </main>

      <!-- FOOT -->
      <footer class="border-t border-white/10 px-6 py-4 text-center text-xs text-white/30">
        © AVYNA Saltillo · Distribuidor autorizado
      </footer>

    </div>

  </div>

<script type="module">
import { supabase } from "/src/lib/supabase.ts";

/* USER DATA */
async function loadUser() {

  const {
    data: { user }
  } = await supabase.auth.getUser();

  if (!user) return;

  document.getElementById("sidebarEmail").textContent =
    user.email || "";

  const { data: profile } = await supabase
    .from("profiles")
    .select("first_name")
    .eq("id", user.id)
    .maybeSingle();

  if (profile?.first_name) {
    document.getElementById("sidebarName").textContent =
      profile.first_name;
  }
}

/* LOGOUT */
async function logout() {
  await supabase.auth.signOut();
  window.location.href = "/auth/login";
}

document
  .getElementById("logoutBtn")
  ?.addEventListener("click", logout);

document
  .getElementById("mobileLogout")
  ?.addEventListener("click", logout);

loadUser();
</script>

</body>
</html>