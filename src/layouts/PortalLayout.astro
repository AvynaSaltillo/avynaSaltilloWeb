---
import "../styles/global.css";

import { APP } from "../config/app"

import {
  RiHome5Line,
  RiAddCircleLine,
  RiDashboardLine,
  RiUserLine,
  RiShoppingBag3Line,
  RiCustomerService2Line,
  RiLogoutBoxRLine,
  RiMenuFoldLine,
  RiMenuUnfoldLine,
  RiMenu3Line,
  RiCloseLine
} from "react-icons/ri";

const { title = "Portal AVYNA" } = Astro.props;
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
</head>

<body class="min-h-screen bg-black text-white antialiased">

<!-- BG -->
<div class="fixed inset-0 -z-10 overflow-hidden">
  <div class="absolute inset-0 bg-black"></div>
  <div class="absolute left-[-10%] top-[-10%] h-144 w-xl rounded-full bg-white/3 blur-3xl"></div>
  <div class="absolute bottom-[-10%] right-[-10%] h-160 w-160 rounded-full bg-white/2 blur-3xl"></div>
</div>

<div class="flex min-h-screen">

  <!-- DESKTOP SIDEBAR -->
  <aside
    id="sidebar"
    class="hidden lg:flex h-screen sticky top-0 shrink-0 flex-col border-r border-white/10 bg-white/2.5 backdrop-blur-2xl transition-all duration-300 w-75 min-w-75 overflow-hidden"
  >

    <!-- TOP -->
    <div class="border-b border-white/10 px-5 pt-5 pb-4">

      <div class="flex items-center justify-between gap-3">

        <div class="label-wrap min-w-0">
          <p class="text-[10px] uppercase tracking-[0.42em] text-white/28">
            AVYNA SALTILLO
          </p>

          <h1 class="mt-3 text-[30px] leading-[1.05] font-semibold tracking-tight">
            Portal
            <br />
          </h1>
        </div>

        <button
          id="toggleSidebar"
          class="grid h-11 w-11 place-items-center rounded-2xl border border-white/10 bg-white/3 text-white/70 transition hover:bg-white/10 hover:text-white"
        >
          <RiMenuFoldLine id="iconOpen" size={19}/>
          <RiMenuUnfoldLine id="iconClose" size={19} className="hidden"/>
        </button>

      </div>

    </div>

    <!-- NAV -->
    <nav class="flex-1 overflow-y-auto px-4 py-5 space-y-2">

      <a href="/portal/" class="nav-link">
        <RiHome5Line size={20}/>
        <span class="label-wrap">Inicio</span>
      </a>

      <a href="/portal/new-order" class="nav-link">
        <RiAddCircleLine size={20}/>
        <span class="label-wrap">Pedido nuevo</span>
      </a>

      <div class="my-4 border-t border-white/10"></div>

      <a href="/portal/orders" class="nav-link">
        <RiShoppingBag3Line size={20}/>
        <span class="label-wrap">Pedidos</span>
      </a>
      
      <a href="/portal/profile" class="nav-link">
        <RiUserLine size={20}/>
        <span class="label-wrap">Mi perfil</span>
      </a>

      <a href="/portal/support" class="nav-link">
        <RiCustomerService2Line size={20}/>
        <span class="label-wrap">Soporte</span>
      </a>

    </nav>

    <!-- FOOT -->
    <div class="mt-auto border-t border-white/10 p-4">

      <div class="rounded-[28px] border border-white/10 bg-black/45 p-4">

        <div class="flex items-start gap-3">

          <div
            id="sidebarAvatar"
            class="grid h-11 w-11 place-items-center rounded-2xl bg-white text-black font-semibold"
          >
            A
          </div>

          <div class="min-w-0 label-wrap">
            <p id="sidebarName" class="truncate font-semibold">
              Cliente
            </p>

            <p id="sidebarEmail" class="mt-1 truncate text-xs text-white/42">
              cargando...
            </p>
          </div>

        </div>

        <button
          id="logoutBtn"
          class="mt-4 flex h-12 w-full items-center justify-center gap-2 rounded-2xl bg-white font-semibold text-black"
        >
          <RiLogoutBoxRLine size={18}/>
          <span class="label-wrap">Cerrar sesión</span>
        </button>

      </div>

    </div>

      
  <footer class="border-t border-white/5 px-6 py-4">

  <div class="flex items-center justify-between text-xs text-white/25">

    <p>
      {APP.copyright}
    </p>

    <p>
      {APP.version}
    </p>

  </div>

</footer>

  </aside>

  <!-- MOBILE MENU -->
<div
  id="mobileOverlay"
  class="fixed inset-0 z-50 hidden bg-black/70 backdrop-blur-sm lg:hidden"
></div>

  <aside
  id="mobileSidebar"
  class="fixed left-0 top-0 z-60 h-screen w-72.5 translate-x-[-100%] transition-transform duration-300 ease-out flex flex-col bg-black border-r border-white/10"
>

    <div class="border-b border-white/10 px-5 py-5 flex items-center justify-between">

      <div>
        <p class="text-[10px] uppercase tracking-[0.35em] text-white/30">
          AVYNA
        </p>

        <p class="mt-1 font-semibold">
          Portal
        </p>
      </div>

      <button
        id="closeMobileMenu"
        class="grid h-10 w-10 place-items-center rounded-xl border border-white/10"
      >
        <RiCloseLine size={20}/>
      </button>

    </div>

    <nav class="p-4 space-y-2">

      <a href="/portal/" class="nav-link mobile-link">
        <RiHome5Line size={20}/>
        <span>Inicio</span>
      </a>

      <a href="/portal/new-order" class="nav-link mobile-link">
        <RiAddCircleLine size={20}/>
        <span>Pedido nuevo</span>
      </a>

      <div class="my-4 border-t border-white/10"></div>

      <a href="/portal/orders" class="nav-link mobile-link">
        <RiShoppingBag3Line size={20}/>
        <span>Pedidos</span>
      </a>

            <a href="/portal/profile" class="nav-link mobile-link">
        <RiUserLine size={20}/>
        <span>Mi perfil</span>
      </a>

      <a href="/portal/support" class="nav-link mobile-link">
        <RiCustomerService2Line size={20}/>
        <span>Soporte</span>
      </a>

    </nav>

    
    <div class="mt-auto border-t border-white/10 p-4">

  <div class="rounded-[28px] border border-white/10 bg-white/5 backdrop-blur-xl p-4">

    <div class="flex items-center gap-3">

      <!-- AVATAR -->
      <div
        id="mobileAvatar"
        class="grid h-11 w-11 place-items-center rounded-2xl bg-white text-black font-semibold"
      >
        A
      </div>

      <!-- USER INFO -->
      <div class="min-w-0">
        <p id="mobileName" class="truncate font-semibold">
          Cliente
        </p>

        <p id="mobileEmail" class="text-xs text-white/40 truncate">
          cargando...
        </p>
      </div>

    </div>

    <!-- LOGOUT -->
    <button
      id="mobileLogout"
      class="mt-4 flex h-11 w-full items-center justify-center gap-2 rounded-2xl bg-white text-black font-semibold"
    >
      <RiLogoutBoxRLine size={18}/>
      Cerrar sesión
    </button>

  </div>

</div>


  </aside>

  <!-- MAIN -->
  <div class="flex min-h-screen flex-1 flex-col">

    <!-- MOBILE HEADER -->
    <header class="lg:hidden sticky top-0 z-30 border-b border-white/10 bg-black/80 backdrop-blur-xl">

      <div class="flex items-center justify-between px-4 py-4">

        <div class="flex items-center gap-3">

          <button
            id="openMobileMenu"
            class="grid h-10 w-10 place-items-center rounded-xl border border-white/10"
          >
            <RiMenu3Line size={20}/>
          </button>

          <div>
            <p class="text-[10px] uppercase tracking-[0.35em] text-white/35">
              AVYNA
            </p>

            <p class="text-sm font-semibold">
              Portal Privado
            </p>
          </div>

        </div>
      </div>

    </header>

    <main class="flex-1 p-4 sm:p-6 lg:p-8">
      <div class="mx-auto w-full max-w-[420px] lg:max-w-7xl">
        <slot />
      </div>
    </main>

  </div>

</div>

<style>
.nav-link{
display:flex;
align-items:center;
gap:14px;
height:56px;
padding:0 16px;
border-radius:18px;
color:rgba(255,255,255,.72);
transition:.22s ease;
white-space:nowrap;
}

.nav-link:hover:not(.active-link){
background:rgba(255,255,255,.06);
color:#fff;
transform:translateX(3px);
}

.active-link{
background:#fff;
color:#000 !important;
font-weight:700;
pointer-events:none;
}

.active-link svg{
color:#000 !important;
}

/* collapsed desktop */
.sidebar-collapsed{
width:96px !important;
min-width:96px !important;
}

.sidebar-collapsed .label-wrap{
display:none !important;
}

.sidebar-collapsed .nav-link{
width:58px;
height:58px;
padding:0;
justify-content:center;
}

.sidebar-collapsed nav{
padding:18px 0;
display:flex;
flex-direction:column;
align-items:center;
}

.sidebar-collapsed .nav-link span{
display:none;
}

.sidebar-collapsed #logoutBtn span{
display:none;
}

/* mobile products responsive */
@media (max-width:1023px){

#productsGrid .grid{
grid-template-columns:1fr 90px 120px !important;
}

#productsGrid .hide-mobile{
display:none !important;
}

#productsGrid .product-name{
font-size:14px;
line-height:1.3;
white-space:normal !important;
}

}
</style>

<script>
  import "../scripts/portal.ts";
</script>

</body>
</html>