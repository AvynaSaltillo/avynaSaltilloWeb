---
import "../styles/global.css";
import "../styles/auth.css";

const {
  title = "Acceso AVYNA Saltillo",
  subtitle = "Portal exclusivo para clientes activos de nuestra distribución oficial."
} = Astro.props;
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
</head>

<body class="auth-scope min-h-screen overflow-x-hidden bg-black text-white antialiased">

  <!-- BACKGROUND -->
  <div class="fixed inset-0 -z-10 overflow-hidden">

    <div class="absolute inset-0 bg-black"></div>

    <div class="absolute left-[-8%] top-[-8%] h-72 w-72 rounded-full bg-white/4 blur-3xl"></div>

    <div class="absolute bottom-[-10%] right-[-10%] h-96 w-96 rounded-full bg-white/3 blur-3xl"></div>

    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.05),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(255,255,255,0.04),transparent_28%)]"></div>

  </div>

  <!-- WRAPPER -->
  <main class="min-h-screen lg:grid lg:grid-cols-[1.18fr_0.82fr]">

    <!-- LEFT -->
    <section class="hidden min-h-screen border-r border-white/10 lg:flex lg:flex-col lg:justify-start">

      <!-- TOP -->
      <div class="px-10 pt-8">

        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/3 px-4 py-2 text-sm font-medium text-white/75 transition hover:bg-white/10 hover:text-white"
        >
          ← Volver al sitio
        </a>

      </div>

      <!-- CONTENT -->
      <div class="px-10 pt-14 pb-10">

        <img
          src="/images/logo-avyna-white.png"
          alt="AVYNA"
          class="mb-3 h-10 w-auto opacity-95"
        />

        <p class="mb-8 text-[13px] uppercase tracking-[0.38em] text-white/30">
          DISTRIBUIDOR OFICIAL · SALTILLO
        </p>

        <h1 class="max-w-2xl text-5xl font-semibold leading-[1.02] tracking-tight xl:text-6xl">
          Portal privado para clientes activos.
        </h1>

        <p class="mt-7 max-w-xl text-lg leading-relaxed text-white/55">
          Realiza pedidos, consulta estatus, revisa historial y recibe soporte directo de AVYNA Saltillo.
        </p>

        <!-- FEATURES -->
        <div class="mt-10 grid max-w-xl gap-4">

          <div class="rounded-2xl border border-white/10 bg-white/3 p-4">
            <p class="font-medium">Pedidos en línea</p>
            <p class="mt-1 text-sm text-white/45">
              Solicita surtido disponible de forma sencilla.
            </p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/3 p-4">
            <p class="font-medium">Perfil e historial</p>
            <p class="mt-1 text-sm text-white/45">
              Compras anteriores y atención personalizada.
            </p>
          </div>

        </div>

      </div>

    </section>

    <!-- RIGHT -->
    <section class="flex min-h-screen items-start justify-center px-4 py-6 sm:px-6 lg:px-10 lg:pt-14">

      <div class="w-full max-w-lg">

        <!-- MOBILE -->
        <div class="mb-5 lg:hidden">

          <a
            href="/"
            class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/3 px-4 py-2 text-sm text-white/75"
          >
            ← Inicio
          </a>

        </div>

        <!-- CARD -->
        <div class="relative rounded-3xl border border-white/10 bg-white/3 shadow-2xl backdrop-blur-xl">

          <!-- SCROLL PANEL -->
          <div
            id="authPanel"
            class="premium-scroll max-h-[92vh] overflow-y-auto rounded-3xl p-6 sm:p-7"
          >


            <p class="text-[11px] uppercase tracking-[0.38em] text-white/30">
              CLIENT ACCESS
            </p>

            <h2 class="mt-3 text-3xl font-semibold tracking-tight">
              {title}
            </h2>

            <p class="mt-2 text-sm leading-relaxed text-white/50">
              {subtitle}
            </p>

            <!-- SLOT -->
            <div class="mt-6 pb-4">
              <slot />
            </div>

          </div>

          <!-- SMART FADE -->
          <div
            id="scrollFade"
            class="pointer-events-none absolute bottom-0 left-0 right-0 h-20 rounded-b-3xl bg-linear-to-t from-black via-black/75 to-transparent opacity-100 transition-opacity duration-300"
          ></div>

        </div>

        <!-- FOOT -->
        <p class="mt-3 text-center text-xs text-white/25">
          © AVYNA Saltillo · Distribuidor autorizado
        </p>

      </div>

    </section>

  </main>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {
  const panel = document.getElementById("authPanel");
  const fade = document.getElementById("scrollFade");

  if (!panel || !fade) return;

  function checkScrollFade() {
    const atBottom =
      panel.scrollTop + panel.clientHeight >= panel.scrollHeight - 8;

    const hasScroll =
      panel.scrollHeight > panel.clientHeight + 8;

    fade.style.opacity =
      hasScroll && !atBottom ? "1" : "0";
  }

  panel.addEventListener("scroll", checkScrollFade);
  window.addEventListener("resize", checkScrollFade);

  checkScrollFade();
});
</script>

</body>
</html>