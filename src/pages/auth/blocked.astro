---
import AuthLayout from "../../layouts/AuthLayout.astro";

import { FaUserSlash } from "react-icons/fa";

---

<AuthLayout title="Cuenta bloqueada | AVYNA Saltillo">

<section class="min-h-[80vh] grid place-items-center px-4">

  <div class="w-full max-w-2xl rounded-4xl border border-white/10 bg-gradient-to-br from-white/5 via-white/2 to-transparent p-8 sm:p-10 text-center">

    <!-- ICON -->
    <div class="mx-auto grid h-20 w-20 place-items-center rounded-full border border-red-400/20 bg-red-400/10">

    <FaUserSlash size={50} />

    </div>

    <!-- TEXT -->
    <p class="mt-8 text-xs uppercase tracking-[0.45em] text-white/35">
      Acceso restringido
    </p>

    <h1 class="mt-4 text-2xl font-semibold tracking-tight sm:text-5xl">
      Cuenta bloqueada
    </h1>

    <p class="mx-auto mt-5 max-w-xl text-sm text-white/55 sm:text-base">
      Tu acceso ha sido restringido temporalmente.
      Si crees que esto es un error o deseas reactivar tu cuenta,
      ponte en contacto con nuestro equipo.
    </p>

    <!-- STATUS -->
    <div class="mt-8 rounded-2xl border border-white/10 bg-white/5 p-5 text-left">

      <div class="flex items-center justify-between gap-3">

        <span class="text-sm text-white/55">
          Estado actual
        </span>

        <span class="rounded-full border border-red-400/20 bg-red-400/10 px-3 py-1 text-xs font-medium text-red-300">
          Bloqueado
        </span>

      </div>

      <p class="mt-4 text-sm text-white/45 leading-2">
        El acceso al portal está deshabilitado hasta nuevo aviso.
      </p>

    </div>

    <!-- ACTIONS -->
    <div class="mt-4 grid gap-3 sm:grid-cols-2">

      <a
        href="/auth/login"
        class="inline-flex h-12 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-sm font-medium text-white/80 hover:bg-white/10"
      >
        Ir a login
      </a>

      <a
        href="https://wa.me/528441234567"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-12 items-center justify-center rounded-2xl bg-white text-sm font-semibold text-black hover:scale-[1.02]"
      >
        Contactar soporte
      </a>

    </div>

    <p class="mt-6 text-xs text-white/30">
      AVYNA Saltillo · Distribuidor autorizado
    </p>

  </div>

</section>

</AuthLayout>