<!-- login.astro (COMPLETO CORREGIDO) -->
---
import AuthLayout from "../../layouts/AuthLayout.astro";
import {
  Mail,
  Lock,
  Eye,
  ArrowRight
} from "lucide-react";
---

<AuthLayout
  title="Bienvenido de nuevo"
  subtitle="Acceso exclusivo para clientes activos AVYNA Saltillo."
>

<form id="loginForm" class="space-y-3">

  <!-- EMAIL -->
  <div class="relative">
    <Mail
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="email"
      type="email"
      placeholder="Correo electrónico"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4 outline-none transition focus:border-white/30"
      required
      autocomplete="email"
    />
  </div>

  <!-- PASSWORD -->
  <div class="relative">
    <Lock
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="password"
      type="password"
      placeholder="Contraseña"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-12 outline-none transition focus:border-white/30"
      required
      autocomplete="current-password"
    />

    <button
      type="button"
      id="togglePassword"
      class="absolute right-3 top-1/2 z-20 -translate-y-1/2 text-white/40 active:scale-95"
      aria-label="Mostrar contraseña"
    >
      <Eye
        size={18}
        className="pointer-events-none"
      />
    </button>
  </div>

  <!-- OPTIONS -->
  <div class="flex items-center justify-between gap-3 pt-1">

    <label class="flex items-center gap-2 text-sm text-white/55">
      <input type="checkbox" />
      <span>Recordarme</span>
    </label>

    <a
      href="/auth/forgot-password"
      class="text-sm text-white/55 hover:text-white"
    >
      ¿Olvidaste tu contraseña?
    </a>

  </div>

  <!-- BUTTON -->
  <button
    id="submitBtn"
    type="submit"
    class="flex h-12 w-full items-center justify-center gap-2 rounded-xl bg-white font-semibold text-black"
  >
    <span id="btnText">Entrar</span>
    <ArrowRight
      size={16}
      className="pointer-events-none"
    />
  </button>

  <p
    id="msg"
    class="min-h-5 text-center text-sm text-white/55"
  ></p>

</form>

<div class="mt-5 border-t border-white/10 pt-5">

  <a
    href="/auth/signup"
    class="flex h-11 w-full items-center justify-center rounded-xl border border-white/10 text-sm font-medium text-white/80 hover:bg-white/10"
  >
    Solicitar acceso
  </a>

</div>

<script type="module">
import { supabase } from "/src/lib/supabase.ts";

window.addEventListener("DOMContentLoaded", () => {

  const form = document.getElementById("loginForm");
  const msg = document.getElementById("msg");
  const submitBtn = document.getElementById("submitBtn");
  const btnText = document.getElementById("btnText");

  const emailInput = document.getElementById("email");
  const password = document.getElementById("password");
  const togglePassword =
    document.getElementById("togglePassword");

  /* OJO FUNCIONAL MOBILE */
  togglePassword?.addEventListener("click", (e) => {
    e.preventDefault();
    e.stopPropagation();

    password.type =
      password.type === "password"
        ? "text"
        : "password";
  });

  function setLoading(state) {
    submitBtn.disabled = state;
    btnText.textContent =
      state ? "Entrando..." : "Entrar";
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    msg.textContent = "";

    const email =
      emailInput.value.trim().toLowerCase();

    const pass =
      password.value.trim();

    if (!email || !pass) {
      msg.textContent =
        "Completa correo y contraseña.";
      return;
    }

    setLoading(true);

    try {

      const { data, error } =
        await supabase.auth.signInWithPassword({
          email,
          password: pass
        });

      if (error || !data.user) {
        msg.textContent =
          "Credenciales inválidas.";
        setLoading(false);
        return;
      }

      const { data: profile } =
        await supabase
          .from("profiles")
          .select("approved, role")
          .eq("id", data.user.id)
          .maybeSingle();

      if (!profile) {
        msg.textContent =
          "No se encontró perfil.";
        setLoading(false);
        return;
      }

      if (profile.approved !== true) {
        window.location.href =
          "/auth/pending";
        return;
      }

      if (profile.role === "admin") {
        window.location.href = "/admin";
        return;
      }

      window.location.href =
        "/portal/dashboard";

    } catch {
      msg.textContent =
        "Ocurrió un error inesperado.";
      setLoading(false);
    }

  });

});
</script>

</AuthLayout>