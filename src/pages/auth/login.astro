---
import AuthLayout from "../../layouts/AuthLayout.astro";

import {
  Mail,
  Lock,
  Eye,
  ArrowRight
} from "lucide-react";
---

<AuthLayout
  title="Bienvenido de nuevo"
  subtitle="Acceso exclusivo para clientes activos AVYNA Saltillo."
>

<form id="loginForm" class="space-y-3">

  <!-- EMAIL -->
  <div class="relative">

    <Mail
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="email"
      type="email"
      placeholder="Correo electrónico"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4 outline-none"
      required
      autocomplete="email"
    />

  </div>

  <!-- PASSWORD -->
  <div class="relative">

    <Lock
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="password"
      type="password"
      placeholder="Contraseña"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-12 outline-none"
      required
      autocomplete="current-password"
    />

    <button
      type="button"
      id="togglePassword"
      class="absolute right-3 top-1/2 -translate-y-1/2 z-20 text-white/40 active:scale-95"
    >
      <Eye
        size={18}
        className="pointer-events-none"
      />
    </button>

  </div>

  <!-- OPTIONS -->
  <div class="flex items-center justify-between gap-3 pt-1">

    <label class="flex items-center gap-2 text-sm text-white/55">
      <input type="checkbox" />
      <span>Recordarme</span>
    </label>

    <a
      href="/auth/forgot-password"
      class="text-sm text-white/55 hover:text-white"
    >
      ¿Olvidaste tu contraseña?
    </a>

  </div>

  <!-- BTN -->
  <button
    id="submitBtn"
    type="submit"
    class="flex h-12 w-full items-center justify-center gap-2 rounded-xl bg-white font-semibold text-black"
  >
    Entrar
    <ArrowRight size={16} />
  </button>

  <p
    id="msg"
    class="min-h-5 text-center text-sm text-white/55"
  ></p>

</form>

<div class="mt-5 border-t border-white/10 pt-5">

  <a
    href="/auth/signup"
    class="flex h-11 w-full items-center justify-center rounded-xl border border-white/10 text-sm font-medium text-white/80 hover:bg-white/10"
  >
    Solicitar acceso
  </a>

</div>

<!-- ✅ IMPORT DENTRO DEL LAYOUT -->
<script type="module" src="/src/scripts/login.ts"></script>

</AuthLayout>