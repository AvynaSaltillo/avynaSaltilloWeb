---
import AuthLayout from "../../layouts/AuthLayout.astro";

import {
  User,
  Building2,
  Mail,
  Phone,
  Lock,
  Eye,
  EyeOff,
  Users,
  ChevronDown
} from "lucide-react";
---

<AuthLayout
  title="Acceso exclusivo"
  subtitle="Registro premium para clientes activos y socios comerciales AVYNA Saltillo."
>

<form
  id="signupForm"
  class="space-y-3"
>

  <!-- NOMBRE -->
  <div class="grid grid-cols-2 gap-3">

    <div class="relative">
      <User
        size={18}
        className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
      />

      <input
        id="firstName"
        placeholder="Nombres"
        class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4 outline-none transition focus:border-white/30"
        required
      />
    </div>

    <div class="relative">
      <User
        size={18}
        className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
      />

      <input
        id="lastName"
        placeholder="Apellidos"
        class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4 outline-none transition focus:border-white/30"
        required
      />
    </div>

  </div>

  <!-- NEGOCIO -->
  <div class="relative">

    <Building2
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="business"
      placeholder="Nombre comercial / salón"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4 outline-none transition focus:border-white/30"
      required
    />

  </div>

  <!-- EMAIL -->
  <div class="relative">

    <Mail
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="email"
      type="email"
      placeholder="Correo electrónico"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4 outline-none transition focus:border-white/30"
      required
    />

  </div>

  <!-- PHONE -->
  <div class="relative">

    <Phone
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="phone"
      inputmode="numeric"
      maxlength="10"
      placeholder="Número de teléfono"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4 outline-none transition focus:border-white/30"
      required
    />

  </div>

  <!-- ASESOR -->
  <div class="space-y-2">

    <p class="px-1 text-xs text-white/45">
      Asesor AVYNA
    </p>

    <input type="hidden" id="advisor" />

    <div class="relative">

      <button
        type="button"
        id="advisorTrigger"
        class="flex h-12 w-full items-center justify-between rounded-xl border border-white/10 bg-black px-4 transition hover:border-white/20"
      >

        <div class="flex items-center gap-3">

          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/5">
            <Users size={16} className="text-white/60" />
          </div>

          <span
            id="advisorLabel"
            class="text-sm text-white/40"
          >
            Selecciona tu asesor AVYNA
          </span>

        </div>

        <ChevronDown
          id="advisorArrow"
          size={16}
          className="text-white/40 transition duration-300"
        />

      </button>

      <!-- MENU -->
      <div
        id="advisorMenu"
        class="absolute left-0 right-0 top-[calc(100%+8px)] z-40 hidden rounded-2xl border border-white/10 bg-zinc-950 p-2 shadow-2xl"
      >

        {[
          "Michelle Navarrete",
          "Ángeles Encinas",
          "Blanca Mejía"
        ].map((name) => (
          <button
            type="button"
            class="advisor-option flex w-full rounded-xl px-3 py-3 text-left text-sm transition hover:bg-white/5"
            data-value={name}
          >
            {name}
          </button>
        ))}

      </div>

    </div>

  </div>

  <!-- PASSWORD -->
  <div class="relative">

    <Lock
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="password"
      type="password"
      minlength="8"
      placeholder="Contraseña (mínimo 8 caracteres)"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-12 outline-none transition focus:border-white/30"
      required
    />

    <button
      type="button"
      id="togglePassword"
      class="absolute right-3 top-1/2 -translate-y-1/2 text-white/40 transition hover:text-white"
    >
      <Eye size={18} />
    </button>

  </div>

  <!-- TERMS -->
  <label class="flex items-start gap-3 rounded-2xl border border-white/10 bg-white/[0.03] p-3 text-[13px] text-white/60">

    <input
      id="terms"
      type="checkbox"
      class="mt-1"
      required
    />

    <span>
      Confirmo que soy cliente AVYNA Saltillo y autorizo contacto comercial.
    </span>

  </label>

  <!-- BUTTON -->
  <button
    id="submitBtn"
    class="h-12 w-full rounded-xl bg-white font-semibold text-black transition hover:scale-[1.01]"
  >
    Crear cuenta
  </button>

  <!-- MESSAGE -->
  <p
    id="msg"
    class="min-h-5 text-center text-sm text-white/55"
  ></p>

</form>

<!-- LOGIN -->
<div class="mt-2 border-t border-white/10 pt-5 text-center">

  <p class="text-sm text-white/45">
    ¿Ya tienes cuenta?
  </p>

  <a
    href="/auth/login"
    class="mt-3 inline-flex rounded-xl border border-white/10 px-4 py-2 text-sm font-medium text-white/80 transition hover:bg-white/10 hover:text-white"
  >
    Iniciar sesión
  </a>

</div>

<script type="module">
import { supabase } from "/src/lib/supabase.ts";

const form = document.getElementById("signupForm");
const msg = document.getElementById("msg");
const submitBtn = document.getElementById("submitBtn");

const phone = document.getElementById("phone");
const password = document.getElementById("password");
const togglePassword = document.getElementById("togglePassword");

const advisor = document.getElementById("advisor");
const advisorTrigger = document.getElementById("advisorTrigger");
const advisorMenu = document.getElementById("advisorMenu");
const advisorArrow = document.getElementById("advisorArrow");
const advisorLabel = document.getElementById("advisorLabel");

/* PHONE */
phone?.addEventListener("input", () => {
  phone.value = phone.value.replace(/\D/g, "").slice(0, 10);
});

/* PASSWORD TOGGLE */
togglePassword?.addEventListener("click", () => {
  const hidden = password.type === "password";

  password.type = hidden ? "text" : "password";

  togglePassword.innerHTML = hidden
    ? `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 3 18 18"/><path d="M10.58 10.58a2 2 0 1 0 2.83 2.83"/><path d="M9.9 4.24A10.94 10.94 0 0 1 12 4c7 0 10 8 10 8a18.5 18.5 0 0 1-2.16 3.19"/><path d="M6.71 6.71A10.94 10.94 0 0 0 2 12s3 8 10 8a10.94 10.94 0 0 0 5.29-1.29"/></svg>`
    : `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>`;
});

/* ADVISOR */
function closeAdvisor() {
  advisorMenu.classList.add("hidden");
  advisorArrow.style.transform = "rotate(0deg)";
}

advisorTrigger?.addEventListener("click", () => {
  const hidden = advisorMenu.classList.contains("hidden");

  if (hidden) {
    advisorMenu.classList.remove("hidden");
    advisorArrow.style.transform = "rotate(180deg)";
  } else {
    closeAdvisor();
  }
});

document.querySelectorAll(".advisor-option").forEach((item) => {
  item.addEventListener("click", () => {
    advisor.value = item.dataset.value;
    advisorLabel.textContent = item.dataset.value;
    advisorLabel.classList.remove("text-white/40");
    advisorLabel.classList.add("text-white");
    closeAdvisor();
  });
});

document.addEventListener("click", (e) => {
  if (
    !e.target.closest("#advisorTrigger") &&
    !e.target.closest("#advisorMenu")
  ) {
    closeAdvisor();
  }
});

/* LOADING */
function setLoading(state) {
  submitBtn.disabled = state;
  submitBtn.textContent =
    state ? "Creando cuenta..." : "Crear cuenta";
}

/* SUBMIT */
form?.addEventListener("submit", async (e) => {
  e.preventDefault();

  msg.textContent = "";

  const firstName =
    document.getElementById("firstName").value.trim();

  const lastName =
    document.getElementById("lastName").value.trim();

  const business =
    document.getElementById("business").value.trim();

  const email =
    document.getElementById("email")
      .value.trim()
      .toLowerCase();

  const phoneVal = phone.value.trim();
  const advisorVal = advisor.value.trim();
  const pass = password.value;

  if (
    !firstName ||
    !lastName ||
    !business ||
    !email ||
    !phoneVal ||
    !advisorVal ||
    !pass
  ) {
    msg.textContent = "Completa todos los campos.";
    return;
  }

  if (phoneVal.length !== 10) {
    msg.textContent = "Número inválido.";
    return;
  }

  if (pass.length < 8) {
    msg.textContent = "La contraseña debe tener mínimo 8 caracteres.";
    return;
  }

  setLoading(true);

  try {
    /* CREATE AUTH */
    const {
      data: authData,
      error: authError
    } = await supabase.auth.signUp({
      email,
      password: pass
    });

    if (authError) {
      msg.textContent = authError.message;
      setLoading(false);
      return;
    }

    let uid = authData?.user?.id;

    /* FALLBACK */
    if (!uid) {
      const {
        data: userData
      } = await supabase.auth.getUser();

      uid = userData?.user?.id;
    }

    if (!uid) {
      msg.textContent =
        "No se pudo crear usuario.";
      setLoading(false);
      return;
    }

    /* FOLIO */
    const { count } = await supabase
      .from("profiles")
      .select("*", {
        count: "exact",
        head: true
      });

    const localId =
      "AVY-" +
      String((count || 0) + 1).padStart(4, "0");

    /* PROFILE INSERT */
    const {
      error: profileError
    } = await supabase
      .from("profiles")
      .insert({
        id: uid,
        email,
        first_name: firstName,
        last_name: lastName,
        name: `${firstName} ${lastName}`,
        business_name: business,
        phone: phoneVal,
        advisor: advisorVal,
        city: "Saltillo",
        role: "client",
        approved: false,
        local_client_id: localId
      });

    if (profileError) {
      msg.textContent =
        "Cuenta creada, pero faltó guardar perfil.";
      setLoading(false);
      return;
    }

    msg.textContent =
      `Cuenta creada correctamente. Folio ${localId}. Espera aprobación.`;

    form.reset();

    advisor.value = "";
    advisorLabel.textContent =
      "Selecciona tu asesor AVYNA";
    advisorLabel.classList.remove("text-white");
    advisorLabel.classList.add("text-white/40");

  } catch (error) {
    msg.textContent =
      "Ocurrió un error inesperado.";
  }

  setLoading(false);
});
</script>

</AuthLayout>