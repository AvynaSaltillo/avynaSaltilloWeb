---
import AuthLayout from "../../layouts/AuthLayout.astro";

import {
  User,
  Building2,
  Mail,
  Phone,
  Lock,
  Eye,
  Users,
  ChevronDown
} from "lucide-react";
---

<AuthLayout
  title="Acceso exclusivo"
  subtitle="Registro premium para clientes activos y socios comerciales AVYNA Saltillo."
>

<form id="signupForm" class="space-y-3">

  <!-- NOMBRE -->
  <div class="grid grid-cols-2 gap-3">

    <div class="relative">
      <User
        size={18}
        className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
      />

      <input
        id="firstName"
        placeholder="Nombres"
        class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4 outline-none"
        required
      />
    </div>

    <div class="relative">
      <User
        size={18}
        className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
      />

      <input
        id="lastName"
        placeholder="Apellidos"
        class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4 outline-none"
        required
      />
    </div>

  </div>

  <!-- NEGOCIO -->
  <div class="relative">

    <Building2
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="business"
      placeholder="Nombre comercial / salón"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4 outline-none"
      required
    />

  </div>

  <!-- EMAIL -->
  <div class="relative">

    <Mail
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="email"
      type="email"
      placeholder="Correo electrónico"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4 outline-none"
      required
      autocomplete="email"
    />

  </div>

  <!-- PHONE -->
  <div class="relative">

    <Phone
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="phone"
      inputmode="numeric"
      maxlength="10"
      placeholder="Número de teléfono"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4 outline-none"
      required
      autocomplete="tel"
    />

  </div>

  <!-- ASESOR -->
  <div class="space-y-2">

    <p class="px-1 text-xs text-white/45">
      Asesor AVYNA
    </p>

    <input type="hidden" id="advisor" />

    <div class="relative">

      <button
        type="button"
        id="advisorTrigger"
        class="flex h-12 w-full items-center justify-between rounded-xl border border-white/10 bg-black px-4"
      >

        <div class="flex items-center gap-3">

          <div class="grid h-8 w-8 place-items-center rounded-lg bg-white/5">
            <Users
              size={16}
              className="pointer-events-none text-white/60"
            />
          </div>

          <span
            id="advisorLabel"
            class="text-sm text-white/40"
          >
            Selecciona tu asesor
          </span>

        </div>

        <ChevronDown
          id="advisorArrow"
          size={16}
          className="pointer-events-none text-white/40 transition"
        />

      </button>

      <div
        id="advisorMenu"
        class="absolute left-0 right-0 top-[calc(100%+8px)] z-40 hidden rounded-2xl border border-white/10 bg-zinc-950 p-2 shadow-2xl"
      >

        {[
          "Michelle Navarrete",
          "Ángeles Encinas",
          "Blanca Mejía"
        ].map((name) => (
          <button
            type="button"
            class="advisor-option flex w-full rounded-xl px-3 py-3 text-left text-sm hover:bg-white/5"
            data-value={name}
          >
            {name}
          </button>
        ))}

      </div>

    </div>

  </div>

  <!-- PASSWORD -->
  <div class="relative">

    <Lock
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="password"
      type="password"
      minlength="8"
      placeholder="Contraseña (mínimo 8 caracteres)"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-12 outline-none"
      required
      autocomplete="new-password"
    />

    <button
      type="button"
      id="togglePassword"
      class="absolute right-3 top-1/2 -translate-y-1/2 z-20 text-white/40 active:scale-95"
    >
      <Eye
        size={18}
        className="pointer-events-none"
      />
    </button>

  </div>

  <!-- TERMS -->
  <label class="flex gap-3 rounded-2xl border border-white/10 bg-white/3 p-3 text-[13px] text-white/60">

    <input
      id="terms"
      type="checkbox"
      required
    />

    <span>
      Confirmo que soy cliente AVYNA Saltillo.
    </span>

  </label>

  <!-- BTN -->
  <button
    id="submitBtn"
    type="submit"
    class="h-12 w-full rounded-xl bg-white font-semibold text-black"
  >
    Crear cuenta
  </button>

  <p
    id="msg"
    class="min-h-5 text-center text-sm text-white/55"
  ></p>

</form>

<div class="mt-5 border-t border-white/10 pt-5">

  <a
    href="/auth/login"
    class="flex h-11 w-full items-center justify-center rounded-xl border border-white/10 text-sm font-medium text-white/80 hover:bg-white/10"
  >
    Iniciar sesión
  </a>

</div>

<script type="module">
import { supabase } from "/src/lib/supabase.ts";

document.addEventListener("DOMContentLoaded", () => {

  const $ = (id) =>
    document.getElementById(id);

  const form = $("signupForm");
  const msg = $("msg");
  const btn = $("submitBtn");

  const phone = $("phone");
  const password = $("password");
  const eye = $("togglePassword");

  const advisor = $("advisor");
  const trigger = $("advisorTrigger");
  const menu = $("advisorMenu");
  const label = $("advisorLabel");
  const arrow = $("advisorArrow");

  if (!form || !msg || !btn) return;

  /* PHONE */
  phone?.addEventListener("input", () => {
    phone.value =
      phone.value
        .replace(/\D/g, "")
        .slice(0, 10);
  });

  /* 👁 PASSWORD */
  eye?.addEventListener("click", (e) => {
    e.preventDefault();

    password.type =
      password.type === "password"
        ? "text"
        : "password";
  });

  /* ASESOR */
  function closeMenu() {
    menu?.classList.add("hidden");

    if (arrow) {
      arrow.style.transform =
        "rotate(0deg)";
    }
  }

  trigger?.addEventListener("click", (e) => {
    e.preventDefault();
    e.stopPropagation();

    menu?.classList.toggle("hidden");

    if (arrow && menu) {
      arrow.style.transform =
        menu.classList.contains("hidden")
          ? "rotate(0deg)"
          : "rotate(180deg)";
    }
  });

  document
    .querySelectorAll(".advisor-option")
    .forEach((item) => {
      item.addEventListener("click", () => {
        const val =
          item.dataset.value || "";

        advisor.value = val;

        if (label) {
          label.textContent = val;
          label.classList.remove(
            "text-white/40"
          );
          label.classList.add(
            "text-white"
          );
        }

        closeMenu();
      });
    });

  document.addEventListener(
    "click",
    (e) => {
      const target = e.target;

      if (
        !target.closest("#advisorTrigger") &&
        !target.closest("#advisorMenu")
      ) {
        closeMenu();
      }
    }
  );

  function loading(state) {
    btn.disabled = state;
    btn.textContent =
      state
        ? "Creando cuenta..."
        : "Crear cuenta";
  }

  /* SUBMIT */
  form.addEventListener(
    "submit",
    async (e) => {
      e.preventDefault();

      msg.textContent = "";

      const first =
        $("firstName").value.trim();

      const last =
        $("lastName").value.trim();

      const business =
        $("business").value.trim();

      const email =
        $("email")
          .value.trim()
          .toLowerCase();

      const phoneVal =
        phone.value.trim();

      const advisorVal =
        advisor.value.trim();

      const pass =
        password.value.trim();

      if (
        !first ||
        !last ||
        !business ||
        !email ||
        !phoneVal ||
        !advisorVal ||
        !pass
      ) {
        msg.textContent =
          "Completa todos los campos.";
        return;
      }

      loading(true);

      try {
        await supabase.auth.signOut();

        const { data, error } =
          await supabase.auth.signUp({
            email,
            password: pass
          });

        if (error || !data.user) {
          msg.textContent =
            error?.message ||
            "No se pudo crear usuario.";

          loading(false);
          return;
        }

        const uid =
          data.user.id;

        const { count } =
          await supabase
            .from("profiles")
            .select("*", {
              count: "exact",
              head: true
            });

        const folio =
          "AVY-" +
          String(
            (count || 0) + 1
          ).padStart(4, "0");

        const {
          error: profileError
        } =
          await supabase
            .from("profiles")
            .insert({
              id: uid,
              email,
              first_name: first,
              last_name: last,
              name:
                `${first} ${last}`,
              business_name:
                business,
              phone: phoneVal,
              advisor:
                advisorVal,
              city: "Saltillo",
              role: "client",
              approved: false,
              local_client_id:
                folio
            });

        if (profileError) {
          msg.textContent =
            profileError.message;

          loading(false);
          return;
        }

        window.location.href =
          "/auth/pending";

      } catch {
        msg.textContent =
          "Error inesperado.";

        loading(false);
      }
    }
  );
});
</script>

</AuthLayout>