<!-- signup.astro CORREGIDO COMPLETO -->
---
import AuthLayout from "../../layouts/AuthLayout.astro";
import {
  User,
  Building2,
  Mail,
  Phone,
  Lock,
  Users,
  ChevronDown
} from "lucide-react";
---

<AuthLayout
  title="Acceso exclusivo"
  subtitle="Registro premium para clientes activos y socios comerciales AVYNA Saltillo."
>

<form id="signupForm" class="space-y-3">

  <!-- NOMBRE -->
  <div class="grid grid-cols-2 gap-3">

    <div class="relative">
      <User
        size={18}
        className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
      />

      <input
        id="firstName"
        placeholder="Nombres"
        class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4"
        required
      />
    </div>

    <div class="relative">
      <User
        size={18}
        className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
      />

      <input
        id="lastName"
        placeholder="Apellidos"
        class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4"
        required
      />
    </div>

  </div>

  <!-- NEGOCIO -->
  <div class="relative">
    <Building2
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="business"
      placeholder="Nombre comercial / salón"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4"
      required
    />
  </div>

  <!-- EMAIL -->
  <div class="relative">
    <Mail
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="email"
      type="email"
      placeholder="Correo electrónico"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4"
      required
    />
  </div>

  <!-- PHONE -->
  <div class="relative">
    <Phone
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="phone"
      inputmode="numeric"
      maxlength="10"
      placeholder="Número de teléfono"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4"
      required
    />
  </div>

  <!-- ASESOR -->
  <div class="space-y-2">

    <p class="px-1 text-xs text-white/45">
      Asesor AVYNA
    </p>

    <input type="hidden" id="advisor" />

    <div class="relative">

      <button
        type="button"
        id="advisorTrigger"
        class="flex h-12 w-full items-center justify-between rounded-xl border border-white/10 bg-black px-4"
      >

        <div class="flex items-center gap-3">

          <div class="grid h-8 w-8 place-items-center rounded-lg bg-white/5">
            <Users
              size={16}
              className="pointer-events-none text-white/60"
            />
          </div>

          <span
            id="advisorLabel"
            class="text-sm text-white/40"
          >
            Selecciona tu asesor
          </span>

        </div>

        <ChevronDown
          id="advisorArrow"
          size={16}
          className="pointer-events-none text-white/40 transition"
        />

      </button>

      <div
        id="advisorMenu"
        class="absolute left-0 right-0 top-[calc(100%+8px)] z-50 hidden rounded-2xl border border-white/10 bg-zinc-950 p-2 shadow-2xl"
      >

        {[
          "Michelle Navarrete",
          "Ángeles Encinas",
          "Blanca Mejía"
        ].map((name) => (
          <button
            type="button"
            class="advisor-option flex w-full rounded-xl px-3 py-3 text-left text-sm hover:bg-white/5"
            data-value={name}
          >
            {name}
          </button>
        ))}

      </div>

    </div>

  </div>

  <!-- PASSWORD -->
  <div class="relative">

    <Lock
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="password"
      type="password"
      minlength="8"
      placeholder="Contraseña (mínimo 8 caracteres)"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-12"
      required
    />

    <!-- OJO REAL -->
    <button
      type="button"
      data-toggle-password
      data-target="password"
      class="absolute right-3 top-1/2 z-50 -translate-y-1/2 text-white/40"
    >
      <span class="pointer-events-none text-lg">👁</span>
    </button>

  </div>

  <!-- TERMS -->
  <label class="flex gap-3 rounded-2xl border border-white/10 bg-white/[0.03] p-3 text-[13px] text-white/60">

    <input type="checkbox" required />

    <span>
      Confirmo que soy cliente AVYNA Saltillo.
    </span>

  </label>

  <!-- BTN -->
  <button
    id="submitBtn"
    class="h-12 w-full rounded-xl bg-white font-semibold text-black"
  >
    Crear cuenta
  </button>

  <p id="msg" class="min-h-5 text-center text-sm text-white/55"></p>

</form>

<div class="mt-5 border-t border-white/10 pt-5">

  <a
    href="/auth/login"
    class="flex h-11 w-full items-center justify-center rounded-xl border border-white/10 text-sm font-medium text-white/80 hover:bg-white/10"
  >
    Iniciar sesión
  </a>

</div>

<script type="module">
import { supabase } from "/src/lib/supabase.ts";

window.addEventListener("DOMContentLoaded", () => {

  const $ = (id) => document.getElementById(id);

  const form = $("signupForm");
  const msg = $("msg");
  const btn = $("submitBtn");

  const phone = $("phone");

  phone?.addEventListener("input", () => {
    phone.value =
      phone.value.replace(/\D/g, "").slice(0,10);
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    msg.textContent = "";
    btn.disabled = true;
    btn.textContent = "Creando...";

    try {

      const first = $("firstName").value.trim();
      const last = $("lastName").value.trim();
      const business = $("business").value.trim();
      const email = $("email").value.trim().toLowerCase();
      const password = $("password").value.trim();
      const advisor = $("advisor").value.trim();

      const { data, error } =
        await supabase.auth.signUp({
          email,
          password
        });

      if (error || !data.user) {
        msg.textContent =
          error?.message || "Error.";
        btn.disabled = false;
        btn.textContent = "Crear cuenta";
        return;
      }

      await supabase
        .from("profiles")
        .insert({
          id: data.user.id,
          first_name: first,
          last_name: last,
          name: first + " " + last,
          business_name: business,
          email,
          phone: phone.value,
          advisor,
          role: "client",
          approved: false
        });

      window.location.href =
        "/auth/pending";

    } catch {
      msg.textContent =
        "Error inesperado.";
      btn.disabled = false;
      btn.textContent =
        "Crear cuenta";
    }

  });

});
</script>

<script is:inline>
(() => {

  function boot() {

    /* OJO */
    document
      .querySelectorAll("[data-toggle-password]")
      .forEach((btn) => {

        function toggle(e) {
          e.preventDefault();
          e.stopPropagation();

          const id =
            btn.dataset.target;

          const input =
            document.getElementById(id);

          if (!input) return;

          input.type =
            input.type === "password"
              ? "text"
              : "password";
        }

        btn.addEventListener("click", toggle);
        btn.addEventListener(
          "touchstart",
          toggle,
          { passive:false }
        );

      });

    /* ASESOR */
    const trigger =
      document.getElementById("advisorTrigger");

    const menu =
      document.getElementById("advisorMenu");

    const hidden =
      document.getElementById("advisor");

    const label =
      document.getElementById("advisorLabel");

    const arrow =
      document.getElementById("advisorArrow");

    trigger?.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();

      menu.classList.toggle("hidden");

      arrow.style.transform =
        menu.classList.contains("hidden")
          ? "rotate(0deg)"
          : "rotate(180deg)";
    });

    document
      .querySelectorAll(".advisor-option")
      .forEach((item) => {

        item.addEventListener("click", () => {

          const val =
            item.dataset.value;

          hidden.value = val;
          label.textContent = val;
          label.className =
            "text-sm text-white";

          menu.classList.add("hidden");
          arrow.style.transform =
            "rotate(0deg)";
        });

      });

  }

  if (document.readyState === "loading") {
    document.addEventListener(
      "DOMContentLoaded",
      boot
    );
  } else {
    boot();
  }

})();
</script>

</AuthLayout>