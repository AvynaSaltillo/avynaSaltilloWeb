---
import AuthLayout from "../../layouts/AuthLayout.astro";

import {
  User,
  Building2,
  Mail,
  Phone,
  Lock,
  Eye,
  EyeOff,
  Users,
  ChevronDown
} from "lucide-react";
---

<AuthLayout
  title="Acceso exclusivo"
  subtitle="Registro premium para clientes activos y socios comerciales AVYNA Saltillo."
>

<form
  id="signupForm"
  class="space-y-3"
>

  <!-- NOMBRE -->
  <div class="grid grid-cols-2 gap-3">

    <div class="relative">
      <User
        size={18}
        className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
      />

      <input
        id="firstName"
        placeholder="Nombres"
        class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4 outline-none transition focus:border-white/30"
        required
      />
    </div>

    <div class="relative">
      <User
        size={18}
        className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
      />

      <input
        id="lastName"
        placeholder="Apellidos"
        class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4 outline-none transition focus:border-white/30"
        required
      />
    </div>

  </div>

  <!-- NEGOCIO -->
  <div class="relative">

    <Building2
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="business"
      placeholder="Nombre comercial / salón"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4 outline-none transition focus:border-white/30"
      required
    />

  </div>

  <!-- EMAIL -->
  <div class="relative">

    <Mail
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="email"
      type="email"
      placeholder="Correo electrónico"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4 outline-none transition focus:border-white/30"
      required
    />

  </div>

  <!-- PHONE -->
  <div class="relative">

    <Phone
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="phone"
      inputmode="numeric"
      maxlength="10"
      placeholder="Número de teléfono"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-4 outline-none transition focus:border-white/30"
      required
    />

  </div>

  <!-- ASESOR -->
  <div class="space-y-2">

    <p class="px-1 text-xs text-white/45">
      Asesor AVYNA
    </p>

    <input type="hidden" id="advisor" />

    <div class="relative">

      <button
        type="button"
        id="advisorTrigger"
        class="flex h-12 w-full items-center justify-between rounded-xl border border-white/10 bg-black px-4 transition hover:border-white/20"
      >

        <div class="flex items-center gap-3">

          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/5">
            <Users size={16} className="text-white/60" />
          </div>

          <span
            id="advisorLabel"
            class="text-sm text-white/40"
          >
            Selecciona tu asesor AVYNA
          </span>

        </div>

        <ChevronDown
          id="advisorArrow"
          size={16}
          className="text-white/40 transition duration-300"
        />

      </button>

      <!-- MENU -->
      <div
        id="advisorMenu"
        class="absolute left-0 right-0 top-[calc(100%+8px)] z-40 hidden rounded-2xl border border-white/10 bg-zinc-950 p-2 shadow-2xl"
      >

        {[
          "Michelle Navarrete",
          "Ángeles Encinas",
          "Blanca Mejía"
        ].map((name) => (
          <button
            type="button"
            class="advisor-option flex w-full rounded-xl px-3 py-3 text-left text-sm transition hover:bg-white/5"
            data-value={name}
          >
            {name}
          </button>
        ))}

      </div>

    </div>

  </div>

  <!-- PASSWORD -->
  <div class="relative">

    <Lock
      size={18}
      className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-white/35"
    />

    <input
      id="password"
      type="password"
      minlength="8"
      placeholder="Contraseña (mínimo 8 caracteres)"
      class="h-12 w-full rounded-xl border border-white/10 bg-black pl-11 pr-12 outline-none transition focus:border-white/30"
      required
    />

    <button
      type="button"
      id="togglePassword"
      class="absolute right-3 top-1/2 -translate-y-1/2 text-white/40 transition hover:text-white"
    >
      <Eye size={18} />
    </button>

  </div>

  <!-- TERMS -->
  <label class="flex items-start gap-3 rounded-2xl border border-white/10 bg-white/[0.03] p-3 text-[13px] text-white/60">

    <input
      id="terms"
      type="checkbox"
      class="mt-1"
      required
    />

    <span>
      Confirmo que soy cliente AVYNA Saltillo y autorizo contacto comercial.
    </span>

  </label>

  <!-- BUTTON -->
  <button
    id="submitBtn"
    class="h-12 w-full rounded-xl bg-white font-semibold text-black transition hover:scale-[1.01]"
  >
    Crear cuenta
  </button>

  <!-- MESSAGE -->
  <p
    id="msg"
    class="min-h-5 text-center text-sm text-white/55"
  ></p>

</form>

<!-- LOGIN -->
<div class="mt-2 border-t border-white/10 pt-5 text-center">

  <p class="text-sm text-white/45">
    ¿Ya tienes cuenta?
  </p>

  <a
    href="/auth/login"
    class="mt-3 inline-flex rounded-xl border border-white/10 px-4 py-2 text-sm font-medium text-white/80 transition hover:bg-white/10 hover:text-white"
  >
    Iniciar sesión
  </a>

</div>

<script type="module">
import { supabase } from "/src/lib/supabase.ts";

window.addEventListener("load", () => {

  const $ = (id) => document.getElementById(id);

  const form = $("signupForm");
  const msg = $("msg");
  const btn = $("submitBtn");

  const phone = $("phone");
  const password = $("password");
  const eye = $("togglePassword");

  const advisor = $("advisor");
  const trigger = $("advisorTrigger");
  const menu = $("advisorMenu");
  const label = $("advisorLabel");
  const arrow = $("advisorArrow");

  /* PHONE */
  phone?.addEventListener("input", () => {
    phone.value = phone.value
      .replace(/\D/g, "")
      .slice(0, 10);
  });

  /* OJO PASSWORD */
  eye?.addEventListener("click", (e) => {
    e.preventDefault();
    e.stopPropagation();

    password.type =
      password.type === "password"
        ? "text"
        : "password";
  });

  /* ASESOR MENU */
  function closeMenu() {
    menu?.classList.add("hidden");

    if (arrow) {
      arrow.style.transform = "rotate(0deg)";
    }
  }

  trigger?.addEventListener("click", (e) => {
    e.preventDefault();
    e.stopPropagation();

    menu?.classList.toggle("hidden");

    if (arrow) {
      arrow.style.transform =
        menu.classList.contains("hidden")
          ? "rotate(0deg)"
          : "rotate(180deg)";
    }
  });

  document
    .querySelectorAll(".advisor-option")
    .forEach((item) => {
      item.addEventListener("click", (e) => {
        e.preventDefault();

        const val =
          item.dataset.value || "";

        advisor.value = val;
        label.textContent = val;

        label.classList.remove("text-white/40");
        label.classList.add("text-white");

        closeMenu();
      });
    });

  document.addEventListener("click", (e) => {
    if (
      !e.target.closest("#advisorTrigger") &&
      !e.target.closest("#advisorMenu")
    ) {
      closeMenu();
    }
  });

  /* LOADING */
  function loading(state) {
    btn.disabled = state;
    btn.textContent =
      state ? "Creando cuenta..." : "Crear cuenta";
  }

  /* SUBMIT */
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    msg.textContent = "";

    const firstName =
      $("firstName").value.trim();

    const lastName =
      $("lastName").value.trim();

    const business =
      $("business").value.trim();

    const email =
      $("email").value
        .trim()
        .toLowerCase();

    const phoneVal =
      phone.value.trim();

    const advisorVal =
      advisor.value.trim();

    const pass =
      password.value.trim();

    if (
      !firstName ||
      !lastName ||
      !business ||
      !email ||
      !phoneVal ||
      !advisorVal ||
      !pass
    ) {
      msg.textContent =
        "Completa todos los campos.";
      return;
    }

    if (phoneVal.length !== 10) {
      msg.textContent =
        "Número inválido.";
      return;
    }

    if (pass.length < 8) {
      msg.textContent =
        "La contraseña debe tener mínimo 8 caracteres.";
      return;
    }

    loading(true);

    try {

      await supabase.auth.signOut();

      const {
        data,
        error
      } = await supabase.auth.signUp({
        email,
        password: pass
      });

      if (error || !data.user) {
        msg.textContent =
          error?.message ||
          "No se pudo crear usuario.";

        loading(false);
        return;
      }

      const uid = data.user.id;

      const { count } =
        await supabase
          .from("profiles")
          .select("*", {
            count: "exact",
            head: true
          });

      const folio =
        "AVY-" +
        String(
          (count || 0) + 1
        ).padStart(4, "0");

      const {
        error: profileError
      } = await supabase
        .from("profiles")
        .insert({
          id: uid,
          email,
          first_name: firstName,
          last_name: lastName,
          name:
            firstName +
            " " +
            lastName,
          business_name: business,
          phone: phoneVal,
          advisor: advisorVal,
          city: "Saltillo",
          role: "client",
          approved: false,
          local_client_id: folio
        });

      if (profileError) {
        msg.textContent =
          profileError.message;

        loading(false);
        return;
      }

      window.location.href =
        "/auth/pending";

    } catch (err) {

      msg.textContent =
        "Error inesperado.";

      loading(false);
    }

  });

});
</script>

</AuthLayout>