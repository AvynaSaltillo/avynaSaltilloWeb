---
import AuthLayout from "../../layouts/AuthLayout.astro";
---

<AuthLayout>

  <h1 class="text-2xl font-semibold mb-6">Iniciar sesión</h1>

  <form id="loginForm" class="flex flex-col gap-4">

    <input 
      type="email" 
      id="email" 
      placeholder="Correo" 
      required 
      class="p-3 bg-neutral-950 border border-neutral-800 rounded"
    />

    <input 
      type="password" 
      id="password" 
      placeholder="Contraseña" 
      required 
      class="p-3 bg-neutral-950 border border-neutral-800 rounded"
    />

    <button 
      class="bg-white text-black p-3 rounded font-medium hover:opacity-90 transition">
      Entrar
    </button>

  </form>

  <p id="error" class="text-red-400 text-sm mt-3 hidden"></p>

</AuthLayout>

<script type="module">
  import { supabase } from "../lib/supabase";

  const form = document.getElementById("loginForm");
  const errorText = document.getElementById("error");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const email = document.getElementById("email").value;
    const password = document.getElementById("password").value;

    errorText.classList.add("hidden");

    const { data, error } = await supabase.auth.signInWithPassword({
      email,
      password
    });

    if (error) {
      errorText.textContent = error.message;
      errorText.classList.remove("hidden");
      return;
    }

    // 🔥 CLAVE: guardar sesión correctamente
    document.cookie = `sb-access-token=${data.session.access_token}; path=/`;
    document.cookie = `sb-refresh-token=${data.session.refresh_token}; path=/`;

    window.location.href = "/admin";
  });
</script>