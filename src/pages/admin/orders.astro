---
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminStats from "../../components/admin/AdminStats.astro";
import AdminTable from "../../components/admin/AdminTable.astro";
---

<AdminLayout>

<section class="space-y-8">

  <!-- HERO -->
  <section class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-gradient-to-br from-zinc-900 via-black to-zinc-950 p-8">

    <div class="absolute -left-20 top-0 h-72 w-72 rounded-full bg-white/[0.03] blur-3xl"></div>
    <div class="absolute right-0 top-0 h-80 w-80 rounded-full bg-white/[0.02] blur-3xl"></div>

    <div class="relative z-10 flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">

      <div>
        <p class="text-xs uppercase tracking-[0.45em] text-white/30">
          Admin Control
        </p>

        <h1 class="mt-4 text-4xl font-semibold tracking-tight sm:text-5xl">
          Pedidos
        </h1>

        <p class="mt-4 max-w-2xl text-sm text-white/55">
          Gestión completa de pedidos, clientes y flujo comercial.
        </p>
      </div>

      <div class="flex gap-3">
        <button id="refreshOrders"
          class="h-12 px-6 rounded-2xl border border-white/20 text-sm text-white/80 hover:bg-white/10">
          Actualizar
        </button>
      </div>

    </div>

  </section>

  <!-- FILTROS -->
  <section class="grid gap-4 lg:grid-cols-[1fr_220px_220px]">

    <input
      id="searchInput"
      type="text"
      placeholder="Buscar pedido o cliente..."
      class="h-14 rounded-2xl border border-white/20 bg-white/[0.03] px-4 text-sm outline-none"
    />

    <select id="statusFilter"
      class="h-14 rounded-2xl border border-white/20 bg-zinc-900 px-4 text-sm">
      <option value="">
  Todos los estatus
</option>

<option value="waiting_supplier">
  Esperando proveedor
</option>

<option value="ordered_supplier">
  Pedido realizado
</option>

<option value="ready_delivery">
  Listo para entrega
</option>

<option value="on_route">
  En ruta
</option>

<option value="delivered">
  Entregado
</option>

<option value="cancelled">
  Cancelado
</option>
    </select>

    <select id="sortFilter"
      class="h-14 rounded-2xl border border-white/20 bg-zinc-900 px-4 text-sm">
      <option value="recent">Más recientes</option>
      <option value="high">Mayor monto</option>
      <option value="low">Menor monto</option>
    </select>

  </section>

  <!-- KPIs -->
  <AdminStats />

  <!-- TABLE -->
  <section class="rounded-[2rem] border border-white/10 bg-white/[0.04] overflow-hidden">

    <div class="overflow-x-auto">
      <AdminTable />
    </div>

  </section>

</section>

<script type="module" src="/src/scripts/admin-orders.ts"></script>

</AdminLayout>