---
import AdminLayout from "../../layouts/AdminLayout.astro";
import ClientsTable from "../../components/admin/ClientsTable.astro";
---

<AdminLayout title="Clientes">

  <section class="space-y-6">

    <!-- ========================================
         HEADER
    ========================================= -->

    <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">

      <!-- LEFT -->
      <div>

        <p class="text-[11px] uppercase tracking-[0.28em] text-white/25">
          Administración
        </p>

        <h1 class="mt-2 text-3xl font-semibold tracking-tight">
          Clientes
        </h1>

        <p class="mt-3 max-w-xl text-sm leading-relaxed text-white/45">
          Gestión de clientes registrados en el sistema AVYNA.
        </p>

      </div>

      <!-- FILTERS -->
      <div class="flex flex-col gap-3 sm:flex-row">

        <select
          id="filterStatus"
          class="h-11 min-w-[180px] rounded-2xl border border-white/10 bg-white/[0.04] px-4 text-sm text-white outline-none backdrop-blur-xl transition focus:border-white/20 focus:bg-white/[0.06]"
        >

          <option value="">
            Todos
          </option>

          <option value="active">
            Activos
          </option>

          <option value="blocked">
            Bloqueados
          </option>

          <option value="pending">
            Pendientes
          </option>

        </select>

      </div>

    </div>

    <!-- ========================================
         TABLE / CARDS
    ========================================= -->

    <div class="card p-3 sm:p-4">

      <ClientsTable />

    </div>

  </section>

  <script>
    import "../../scripts/admin-clients.ts";
  </script>

</AdminLayout>

<!-- ========================================
     MODAL
======================================== -->

<div
  id="clientModal"
  class="fixed inset-0 z-[9999] hidden"
>

  <!-- OVERLAY -->
  <div
    id="modalOverlay"
    class="absolute inset-0 bg-black/75 backdrop-blur-md"
  ></div>

  <!-- WRAPPER -->
  <div class="relative z-10 flex min-h-screen items-end justify-center p-0 sm:items-center sm:p-4">

    <!-- CONTAINER -->
    <div
      id="modalContainer"
      class="max-h-[92vh] w-full overflow-y-auto rounded-t-[2rem] border border-white/10 bg-zinc-900/95 p-5 shadow-[0_0_80px_rgba(0,0,0,0.8)] backdrop-blur-2xl sm:max-w-2xl sm:rounded-3xl sm:p-6"
    >

      <!-- CONTENT -->
      <div id="modalContent"></div>

    </div>

  </div>

</div>