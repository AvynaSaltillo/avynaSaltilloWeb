---
// src/pages/grow/login.astro
import Layout from "../../layouts/GrowLayout.astro";
import {
  ShieldCheck,
  ArrowRight,
  Eye,
  MessageCircle,
  Lock,
  X
} from "lucide-react";

import { BsArrowUpLeftSquareFill } from "react-icons/bs";

---

<Layout title="AVYNA Grow | Oportunidad Comercial En Saltillo">

<meta name="robots" content="noindex,nofollow" />


<!-- SECTION PRINCIPAL -->
<section class="relative min-h-dvh overflow-x-hidden bg-black text-white">

  <!-- BG -->
  <div class="absolute inset-0">
    <div class="absolute -left-32 top-0 h-96 w-96 rounded-full bg-white/5 blur-3xl"></div>
    <div class="absolute -right-32 bottom-0 h-96 w-96 rounded-full bg-white/5 blur-3xl"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,.08),transparent_40%)]"></div>
  </div>

  

  <!-- CONTENT -->
 <div class="relative z-10 mx-auto flex min-h-dvh w-full max-w-md flex-col justify-center px-4 py-6 sm:max-w-lg sm:px-6 md:max-w-xl lg:max-w-xl lg:px-8 lg:py-10">


<a
  href="/"
  class="mb-12 inline-flex h-11 w-fit items-center gap-2 rounded-full border border-white/7 bg-white/2 px-4 text-sm font-medium text-white/75 backdrop-blur-xl transition duration-300 hover:border-white/20 hover:bg-white/10 hover:text-white"
>

    <BsArrowUpLeftSquareFill size={22} opacity={0.9}/>
  Volver al sitio

</a>

    <!-- TOP -->
    <div class="mb-10 text-center lg:mb-10">

      <p class="text-[11px] uppercase tracking-[0.42em] text-white/35 sm:text-xs">
        Acceso Selectivo
      </p>

      <div class="mx-auto mb-3 flex h-16 w-full items-center justify-center sm:h-20">
  <img
    src="/images/logo-avyna-white.png"
    alt="AVYNA"
    class="h-8 w-auto object-contain sm:h-9 lg:h-10"
  />
</div>

      <p class="mx-auto mt-3 max-w-md text-sm leading-relaxed text-white/55 sm:text-base">
  Información exclusiva para profesionales interesados
  en convertirse en Salón AVYNA en Saltillo.
</p>

    </div>

    <!-- CARD -->
    <div class="rounded-4xl border border-white/15 bg-white/4 p-5 shadow-2xl backdrop-blur-2xl sm:p-8 lg:p-8">

      <label class="flex items-center gap-2 text-sm text-white/65">
        <Lock size={14} />
        Clave de acceso
      </label>

      <!-- INPUT -->
      <div class="relative mt-3">

        <input
          id="pass"
          type="password"
          placeholder="Ingresa la clave"
          class="h-14 w-full rounded-2xl border border-white/15 bg-black/55 px-5 pr-14 text-[16px] outline-none transition focus:border-white/40"
        />

        <button
          id="togglePass"
          type="button"
          class="absolute right-4 top-1/2 -translate-y-1/2 text-white/55 transition hover:text-white"
        >
          <Eye size={18} />
        </button>

      </div>

      <!-- ERROR -->
      <p
        id="errorMsg"
        class="mt-4 hidden rounded-2xl border border-red-500/20 bg-red-500/10 px-4 py-3 text-sm text-red-300"
      >
        Clave inválida. Solicita acceso con un distribuidor autorizado.
      </p>

      <!-- BTN LOGIN -->
      <button
        id="loginBtn"
        class="mt-5 flex h-14 w-full items-center justify-center gap-2 rounded-2xl bg-white/90 font-bold text-black transition hover:scale-[1.01]"
      >
        Ingresar con clave
        <ArrowRight size={18} />
      </button>

      <!-- DIVIDER -->
      <div class="my-5 border-t border-white/10"></div>

      <!-- BTN MODAL -->
      <button
        id="openModal"
        class="flex h-14 w-full items-center justify-center gap-2 rounded-2xl border border-white/10 bg-white/5 font-semibold text-white transition hover:bg-white hover:text-black"
      >
        <MessageCircle size={18} />
        Solicitar acceso
      </button>
      
      <!-- FOOT -->
      <div class="mt-3 text-center text-xs leading-relaxed text-white/40 sm:mt-4">
        Acceso temporal de 8 horas · selección previa requerida
      </div>

    </div>

  </div>

  <!-- MODAL -->
<div
  id="advisorModal"
  class="fixed inset-0 z-9999 hidden overflow-y-auto bg-black/75 px-6 py-8 backdrop-blur-md"
>

    <div class="mx-auto my-auto w-full max-w-lg rounded-4xl border border-white/10 bg-zinc-950 p-6 shadow-2xl">

      <!-- HEAD -->
      <div class="flex items-center justify-between">

        <div>
          <p class="text-sm text-white/45">
            Atención personalizada
          </p>

          <h3 class="mt-1 text-2xl font-bold">
            Elige tu asesor AVYNA
          </h3>
        </div>

        <button
          id="closeModal"
          class="flex h-10 w-10 items-center justify-center rounded-xl border border-white/10 text-white/60 hover:bg-white hover:text-black"
        >
          <X size={18} />
        </button>

      </div>

      <p class="mt-4 text-sm leading-relaxed text-white/50">
        Selecciona con quién deseas atenderte para solicitar acceso y recibir seguimiento personalizado.
      </p>

      <!-- OPTIONS -->
      <div class="mt-6 grid gap-3">

          <button
          class="repBtn rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-left transition duration-300 hover:border-white/25 hover:bg-white/10 focus:outline-none focus:ring-0 active:scale-[0.98]"
          data-phone="524521174729"
          data-name="Ángeles"
        >
          <span class="block font-semibold">
            Ángeles Encinas López
          </span>
          <span class="text-sm text-white/40">
            Atención personalizada | Distribuidor
          </span>
        </button>

        <button
          class="repBtn rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-left transition duration-300 hover:border-white/25 hover:bg-white/10 focus:outline-none focus:ring-0 active:scale-[0.98]"
          data-phone="528445069238"
          data-name="Michelle"
        >
          <span class="block font-semibold">
            Michelle Navarrete Zúñiga
          </span>
          <span class="text-sm text-white/45">
            Atención personalizada
          </span>
        </button>

        <button
          class="repBtn rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-left transition duration-300 hover:border-white/25 hover:bg-white/10 focus:outline-none focus:ring-1 active:scale-[0.98]"
          data-phone="528446620304"
          data-name="Blanca"
        >
          <span class="block font-semibold">
            Blanca Mejía Torres
          </span>
          <span class="text-sm text-white/45">
            Atención personalizada
          </span>
        </button>

      </div>

    </div>

  </div>

</section>

<script is:inline>
const KEY = "avyna_grow_access";
const EXP = "avyna_grow_expire";
const PASS = "Avyna#2026";

const input = document.getElementById("pass");
const btn = document.getElementById("loginBtn");
const err = document.getElementById("errorMsg");
const toggle = document.getElementById("togglePass");

/* modal */
const modal = document.getElementById("advisorModal");
const openModal = document.getElementById("openModal");
const closeModal = document.getElementById("closeModal");

input.focus();

/* sesión activa */
const access = localStorage.getItem(KEY);
const expire = Number(localStorage.getItem(EXP) || 0);

if (access === "true" && Date.now() < expire) {
  window.location.pathname = "/grow";
}

/* login */
function login() {

  err.classList.add("hidden");

  if (input.value.trim() !== PASS) {

    err.classList.remove("hidden");

    input.animate(
      [
        { transform: "translateX(-5px)" },
        { transform: "translateX(5px)" },
        { transform: "translateX(0)" }
      ],
      { duration: 180 }
    );

    return;
  }

  btn.disabled = true;
  btn.innerHTML = "Entrando...";

  const newExpire =
    Date.now() + (1000 * 60 * 60 * 8);

  localStorage.setItem(KEY, "true");
  localStorage.setItem(EXP, newExpire.toString());

  window.location.pathname = "/grow";
}

btn.onclick = login;

input.addEventListener("keydown", e => {
  if (e.key === "Enter") login();
});

/* toggle */
let visible = false;

toggle.onclick = () => {
  visible = !visible;
  input.type = visible ? "text" : "password";
};

/* modal open/close */
openModal.onclick = () => {
  modal.classList.remove("hidden");
  modal.classList.add("flex");
};

closeModal.onclick = closeMyModal;

modal.addEventListener("click", e => {
  if (e.target === modal) closeMyModal();
});

function closeMyModal() {
  modal.classList.add("hidden");
  modal.classList.remove("flex");
}

/* reps */
document.querySelectorAll(".repBtn").forEach(btn => {

  btn.addEventListener("click", () => {

    const phone = btn.dataset.phone;
    const name = btn.dataset.name;

    const msg =
`Hola ${name}, me interesa formar parte de AVYNA en Saltillo. ¿Podrías compartirme información para solicitar acceso y conocer beneficios comerciales?`;

    window.open(
      `https://wa.me/${phone}?text=${encodeURIComponent(msg)}`,
      "_blank"
    );

    closeMyModal();

  });

});
</script>

</Layout>