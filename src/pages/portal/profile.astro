---
import PortalLayout from "../../layouts/PortalLayout.astro";
---

<PortalLayout title="Mi Perfil | AVYNA">

<section class="mx-auto max-w-7xl space-y-8">

  <!-- HEADER -->
  <section class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6 lg:p-8">

    <div class="flex flex-col gap-6 sm:flex-row sm:items-center">

      <!-- AVATAR SIMPLE -->
      <div class="relative shrink-0">

        <div
  id="profileAvatar"
  class="relative grid h-28 w-28 place-items-center rounded-full text-4xl font-semibold text-white shadow-xl overflow-hidden"
>
  A
</div>

      </div>

      <!-- INFO -->
      <div class="min-w-0 flex-1">

        <p class="text-xs uppercase tracking-[0.42em] text-white/35">
          CLIENT ACCOUNT
        </p>

        <h1
          id="profileName"
          class="mt-2 text-3xl font-semibold tracking-tight lg:text-5xl"
        >
          Mi Perfil
        </h1>

        <p id="profileBusiness" class="mt-2 text-white/55">
          Negocio
        </p>

        <p id="profileEmail" class="mt-1 text-sm text-white/45">
          cargando...
        </p>

      </div>

      <!-- STATUS -->
      <div class="grid gap-3 sm:w-[260px]">

        <div class="rounded-2xl border border-white/10 bg-black/35 px-5 py-4">
  <p class="text-[11px] uppercase tracking-[0.25em] text-white/35">
    Cliente ID
  </p>

  <div class="mt-2 flex items-center gap-2">
    <p id="profileClientId" class="text-xl font-semibold">
      --
    </p>

    <!-- BADGE -->
    <span
      id="verifiedBadge"
      class="hidden items-center gap-1 rounded-full bg-emerald-500/15 px-2.5 py-1 text-xs font-semibold text-emerald-300"
    >
      ✔ Verificado
    </span>
  </div>
</div>

        <div class="rounded-2xl border border-white/10 bg-black/35 px-5 py-4">
          <p class="text-[11px] uppercase tracking-[0.25em] text-white/35">
            Estado
          </p>
          <p id="profileStatus" class="mt-2 text-xl font-semibold text-emerald-300">
            Activo
          </p>
        </div>

      </div>

    </div>

  </section>

  <!-- GRID -->
  <section class="grid gap-6 xl:grid-cols-[1.15fr_.85fr]">

    <!-- LEFT -->
    <section class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6">

      <div class="flex items-center justify-between gap-3">

        <h2 class="text-2xl font-semibold">
          Información comercial
        </h2>

        <div class="flex gap-2">

          <button id="editProfileBtn" class="action-btn">
            Editar
          </button>

          <button id="cancelProfileBtn" class="action-btn hidden">
            Cancelar
          </button>

          <button id="saveProfileBtn" class="save-btn hidden">
            Guardar
          </button>

        </div>

      </div>

      <div class="mt-6 grid gap-4 sm:grid-cols-2">

        <div class="profile-card sm:col-span-2">
          <p class="profile-label">Nombre completo</p>
          <p id="fullName" class="profile-value">--</p>
        </div>

        <div class="profile-card sm:col-span-2">
          <p class="profile-label">Negocio</p>

          <p id="businessNameText" class="profile-value">--</p>

          <input
            id="businessNameInput"
            class="profile-input hidden"
          />
        </div>

        <div class="profile-card">
          <p class="profile-label">Teléfono</p>

          <p id="phoneText" class="profile-value">--</p>

          <input
            id="phoneInput"
            class="profile-input hidden"
          />
        </div>

        <div class="profile-card">
          <p class="profile-label">Correo</p>

          <p id="emailText" class="profile-value break-all">--</p>

          <input
            id="emailInput"
            type="email"
            class="profile-input hidden"
          />
        </div>

        <div class="profile-card">
          <p class="profile-label">Ciudad</p>
          <p id="city" class="profile-value">Saltillo</p>
        </div>

        <div class="profile-card">
          <p class="profile-label">Asesor</p>
          <p id="advisor" class="profile-value">--</p>
        </div>

      </div>

    </section>

    <!-- RIGHT -->
    <section class="space-y-6">

      <div class="rounded-[2rem] border border-white/10 bg-black/35 p-6">

        <p class="text-xs uppercase tracking-[0.35em] text-white/35">
          Seguridad
        </p>

        <h3 class="mt-4 text-2xl font-semibold">
          Cuenta protegida
        </h3>

        <button
          id="changePasswordBtn"
          class="mt-6 h-11 w-full rounded-2xl bg-white text-sm font-semibold text-black"
        >
          Cambiar contraseña
        </button>

      </div>

      <div class="rounded-[2rem] border border-white/10 bg-black/35 p-6">

        <p class="text-xs uppercase tracking-[0.35em] text-white/35">
          Actividad
        </p>

        <div class="mt-5 space-y-4">

          <div class="flex justify-between">
            <span class="text-white/50">Pedidos totales</span>
            <span id="ordersTotal" class="font-semibold">0</span>
          </div>

          <div class="flex justify-between">
            <span class="text-white/50">Último acceso</span>
            <span id="lastAccess" class="font-semibold">Hoy</span>
          </div>

          <div class="flex justify-between">
            <span class="text-white/50">Miembro desde</span>
            <span id="memberSince" class="font-semibold">--</span>
          </div>

        </div>

      </div>

    </section>

  </section>

</section>

<style>
.profile-card{
border:1px solid rgba(255,255,255,.08);
background:rgba(255,255,255,.03);
border-radius:1.5rem;
padding:1rem;
}
.profile-label{
font-size:.72rem;
letter-spacing:.18em;
text-transform:uppercase;
color:rgba(255,255,255,.38);
}
.profile-value{
margin-top:.35rem;
font-size:1.1rem;
font-weight:600;
}
.profile-input{
margin-top:.7rem;
width:100%;
height:46px;
border:1px solid rgba(255,255,255,.1);
background:#000;
border-radius:1rem;
padding:0 1rem;
}
.action-btn{
height:44px;
padding:0 16px;
border-radius:1rem;
border:1px solid rgba(255,255,255,.1);
}
.save-btn{
height:44px;
padding:0 18px;
border-radius:1rem;
background:#fff;
color:#000;
font-weight:700;
}

.avatar-letter{
font-size:1.8rem;
font-weight:700;
letter-spacing:.02em;
color:#fff;
}

/* base avatar */
#profileAvatar,
#sidebarAvatar{
position:relative;
display:grid;
place-items:center;
border-radius:999px;
overflow:hidden;
transition:.25s ease;
}

/* hover premium */
#profileAvatar:hover,
#sidebarAvatar:hover{
transform:scale(1.06);
filter:brightness(1.08);
}

/* glow real */
#profileAvatar::after,
#sidebarAvatar::after{
content:"";
position:absolute;
inset:0;
border-radius:999px;
box-shadow:0 0 60px rgba(99,102,241,.45);
opacity:.25;
pointer-events:none;
transition:.3s;
}

/* hover glow boost */
#profileAvatar:hover::after,
#sidebarAvatar:hover::after{
opacity:.5;
}
</style>

<script>
  import "../../scripts/profile.ts";
</script>

</PortalLayout>