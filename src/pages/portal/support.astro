---
import PortalLayout from "../../layouts/PortalLayout.astro";
---

<PortalLayout title="Soporte | AVYNA Saltillo">

<section class="space-y-8">

  <!-- HERO -->
  <section class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-gradient-to-br from-zinc-900 via-black to-zinc-950 p-6 sm:p-8 xl:p-10">

    <div class="absolute -left-20 top-0 h-72 w-72 rounded-full bg-white/[0.03] blur-3xl"></div>
    <div class="absolute right-0 top-0 h-80 w-80 rounded-full bg-white/[0.02] blur-3xl"></div>

    <div class="relative z-10 grid gap-8 xl:grid-cols-[1.15fr_.85fr]">

      <!-- LEFT -->
      <div>

        <p class="text-xs uppercase tracking-[0.45em] text-white/30">
          Premium Client Support
        </p>

        <h1 class="mt-5 text-4xl font-semibold tracking-tight sm:text-5xl">
          Soporte prioritario
        </h1>

        <p class="mt-5 max-w-2xl text-sm leading-7 text-white/55 sm:text-base">
          Atención comercial directa para clientes AVYNA Saltillo.
          Resolvemos pedidos, pagos, catálogo, entregas y seguimiento.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">

          <a
            href="https://wa.me/524521174729"
            target="_blank"
            class="inline-flex h-12 items-center justify-center rounded-2xl bg-white px-6 text-sm font-semibold text-black transition hover:scale-[1.02]"
          >
            WhatsApp directo
          </a>

          <a
            href="mailto:soporte@avynasaltillo.beauty"
            class="inline-flex h-12 items-center justify-center rounded-2xl border border-white/10 px-6 text-sm font-medium text-white/80 transition hover:bg-white/10"
          >
            Email soporte
          </a>

        </div>

      </div>

      <!-- RIGHT -->
      <div class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6 backdrop-blur-xl">

        <p class="text-xs uppercase tracking-[0.4em] text-white/30">
          Horario de atención
        </p>

        <div class="mt-6 space-y-4">

          <div class="rounded-2xl border border-white/10 bg-black/30 p-4">
            <p class="font-semibold">
              Lunes a Viernes
            </p>
            <p class="mt-1 text-sm text-white/45">
              9:00 AM — 6:00 PM
            </p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-black/30 p-4">
            <p class="font-semibold">
              Sábados
            </p>
            <p class="mt-1 text-sm text-white/45">
              10:00 AM — 2:00 PM
            </p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-black/30 p-4">
            <p class="font-semibold">
              Tiempo promedio
            </p>
            <p class="mt-1 text-sm text-white/45">
              Respuesta en menos de 15 min.
            </p>
          </div>

        </div>

      </div>

    </div>

  </section>

  <!-- CARDS -->
  <section class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">

    <div class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6">
      <p class="text-xs uppercase tracking-[0.35em] text-white/35">
        Pedidos
      </p>

      <h3 class="mt-4 text-2xl font-semibold">
        Seguimiento comercial
      </h3>

      <p class="mt-3 text-sm leading-7 text-white/50">
        Estado de pedidos, entregas, cambios, incidencias y fechas estimadas.
      </p>
    </div>

    <div class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6">
      <p class="text-xs uppercase tracking-[0.35em] text-white/35">
        Pagos
      </p>

      <h3 class="mt-4 text-2xl font-semibold">
        Facturación y saldos
      </h3>

      <p class="mt-3 text-sm leading-7 text-white/50">
        Anticipos, pagos pendientes, comprobantes y condiciones comerciales.
      </p>
    </div>

    <div class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6">
      <p class="text-xs uppercase tracking-[0.35em] text-white/35">
        Catálogo
      </p>

      <h3 class="mt-4 text-2xl font-semibold">
        Productos
      </h3>

      <p class="mt-3 text-sm leading-7 text-white/50">
        Disponibilidad, novedades, recomendaciones y líneas premium.
      </p>
    </div>

  </section>

  <!-- FAQ -->
  <section class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6 sm:p-8">

    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">

      <div>
        <p class="text-xs uppercase tracking-[0.35em] text-white/35">
          FAQ
        </p>

        <h2 class="mt-2 text-3xl font-semibold">
          Preguntas frecuentes
        </h2>
      </div>

    </div>

    <div class="mt-8 space-y-4">

      <div class="rounded-2xl border border-white/10 bg-black/30 p-5">
        <p class="font-semibold">
          ¿Cómo levanto un pedido?
        </p>

        <p class="mt-2 text-sm text-white/45">
          Desde la sección Pedidos dentro del portal.
        </p>
      </div>

      <div class="rounded-2xl border border-white/10 bg-black/30 p-5">
        <p class="font-semibold">
          ¿Puedo pedir fuera de horario?
        </p>

        <p class="mt-2 text-sm text-white/45">
          Sí, se registra y procesa en el siguiente ciclo operativo.
        </p>
      </div>

      <div class="rounded-2xl border border-white/10 bg-black/30 p-5">
        <p class="font-semibold">
          ¿Cómo reporto un problema?
        </p>

        <p class="mt-2 text-sm text-white/45">
          Escríbenos por WhatsApp directo para atención inmediata.
        </p>
      </div>

    </div>

  </section>

</section>

</PortalLayout>