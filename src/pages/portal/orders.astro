---
import PortalLayout from "../../layouts/PortalLayout.astro";

import {
  FiShoppingBag,
  FiRefreshCw,
  FiSearch,
  FiPackage,
  FiDollarSign,
  FiCreditCard,
  FiChevronLeft,
  FiChevronRight
} from "react-icons/fi";
---

<PortalLayout title="Pedidos | AVYNA Saltillo">

<section class="space-y-8">

  <!-- HERO -->
  <section class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-gradient-to-br from-zinc-900 via-black to-zinc-950 p-6 sm:p-8">

    <div class="absolute -left-16 top-0 h-64 w-64 rounded-full bg-white/[0.05] blur-3xl"></div>
    <div class="absolute right-0 top-0 h-72 w-72 rounded-full bg-white/[0.04] blur-3xl"></div>

    <div class="relative z-10 flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">

      <div>

        <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-xs text-white/60 backdrop-blur-xl">

          <FiPackage size={14} />

          <span class="uppercase tracking-[0.3em]">
            Commercial Orders
          </span>

        </div>

        <h1 class="mt-5 text-4xl font-semibold tracking-tight sm:text-5xl">
          Tus pedidos
        </h1>

        <p class="mt-4 max-w-2xl text-sm leading-7 text-white/60 sm:text-base">
          Consulta historial, saldos, estatus de entrega y actividad comercial.
        </p>

      </div>

      <div class="flex flex-wrap gap-3">

        <a
          href="/portal/new-order"
          class="inline-flex h-12 items-center justify-center gap-2 rounded-2xl bg-white px-6 text-sm font-semibold text-black transition hover:scale-[1.03]"
        >

          <FiShoppingBag size={16} />

          Nuevo pedido

        </a>

        <button
          id="refreshOrders"
          class="inline-flex h-12 items-center justify-center gap-2 rounded-2xl border border-white/20 px-6 text-sm text-white/80 transition hover:bg-white/10"
        >

          <FiRefreshCw size={15} />

          Actualizar

        </button>

      </div>

    </div>

  </section>

  <!-- FILTERS -->
  <section class="grid gap-4 lg:grid-cols-[1fr_220px_220px]">

    <!-- SEARCH -->
    <div class="flex items-center gap-3 rounded-2xl border border-white/20 bg-white/[0.05] px-4 transition focus-within:border-white/40 focus-within:ring-1 focus-within:ring-white/20">

      <FiSearch
        size={18}
        className="text-white/35"
      />

      <input
        id="searchInput"
        type="text"
        placeholder="Buscar pedido..."
        class="h-14 w-full bg-transparent text-sm outline-none placeholder:text-white/40"
      />

    </div>

    <!-- STATUS -->
    <select
      id="statusFilter"
      class="h-14 rounded-2xl border border-white/20 bg-zinc-900 px-4 text-sm text-white outline-none focus:border-white/40 focus:ring-1 focus:ring-white/20"
    >

      <option value="">
        Todos los estatus
      </option>

      <option value="waiting_supplier">
        Esperando proveedor
      </option>

      <option value="ordered_supplier">
        Pedido realizado
      </option>


      <option value="ready_delivery">
        Listo para entrega
      </option>


      <option value="on_route">
  En ruta
</option>

      <option value="delivered">
        Entregado
      </option>

      <option value="cancelled">
        Cancelado
      </option>

    </select>

    <!-- SORT -->
    <select
      id="sortFilter"
      class="h-14 rounded-2xl border border-white/20 bg-zinc-900 px-4 text-sm text-white outline-none focus:border-white/40 focus:ring-1 focus:ring-white/20"
    >

      <option value="recent">
        Más recientes
      </option>

      <option value="high">
        Mayor total
      </option>

      <option value="low">
        Menor total
      </option>

    </select>

  </section>

  <!-- KPIS -->
  <section class="grid gap-4 sm:grid-cols-3">

    <!-- TOTAL -->
    <div class="rounded-[2rem] border border-white/10 bg-white/[0.05] p-6">

      <div class="flex items-center justify-between gap-3">

        <div>

          <p class="text-xs uppercase tracking-[0.35em] text-white/40">
            Total pedidos
          </p>

          <p
            id="ordersTotal"
            class="mt-4 text-4xl font-semibold"
          >
            0
          </p>

        </div>

        <div class="grid h-12 w-12 place-items-center rounded-2xl border border-white/10 bg-white/[0.04] text-white/70">

          <FiPackage size={20} />

        </div>

      </div>

    </div>

    <!-- TOTAL COMPRADO -->
    <div class="rounded-[2rem] border border-white/10 bg-white/[0.05] p-6">

      <div class="flex items-center justify-between gap-3">

        <div>

          <p class="text-xs uppercase tracking-[0.35em] text-white/40">
            Total comprado
          </p>

          <p
            id="ordersAmount"
            class="mt-4 text-4xl font-semibold"
          >
            $0.00
          </p>

        </div>

        <div class="grid h-12 w-12 place-items-center rounded-2xl border border-white/10 bg-white/[0.04] text-white/70">

          <FiDollarSign size={20} />

        </div>

      </div>

    </div>

    <!-- POR PAGAR -->
    <div class="rounded-[2rem] border border-white/10 bg-white/[0.05] p-6">

      <div class="flex items-center justify-between gap-3">

        <div>

          <p class="text-xs uppercase tracking-[0.35em] text-white/40">
            Por pagar
          </p>

          <p
            id="ordersBalance"
            class="mt-4 text-4xl font-semibold"
          >
            $0.00
          </p>

        </div>

        <div class="grid h-12 w-12 place-items-center rounded-2xl border border-white/10 bg-white/[0.04] text-white/70">

          <FiCreditCard size={20} />

        </div>

      </div>

    </div>

  </section>

  <!-- TABLE -->
  <section>

    <div class="overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.05]">

      <!-- TABLE -->
      <div class="w-full overflow-x-auto">

        <table class="min-w-[980px] w-full text-left">

          <thead class="text-xs uppercase tracking-[0.28em] text-white/60">

            <tr class="border-b border-white/10">

              <th class="px-5 py-5 text-left">
                Pedido
              </th>

              <th class="px-5 py-5 text-left">
                Fecha
              </th>

              <th class="px-5 py-5 text-left">
                Delivery
              </th>

              <th class="px-5 py-5 text-left">
                Pago
              </th>

              <th class="px-5 py-5 text-left">
                Total
              </th>

              <th class="px-5 py-5 text-left">
                Por pagar
              </th>

              <th class="px-5 py-5 text-right">
                Acción
              </th>

            </tr>

          </thead>

          <tbody id="ordersTable">

            <tr>

              <td
                colspan="7"
                class="py-14 text-center text-sm text-white/50"
              >
                Cargando pedidos...
              </td>

            </tr>

          </tbody>

        </table>

      </div>

      <!-- PAGINATION -->
      <div class="flex flex-col gap-4 border-t border-white/10 px-5 py-5 sm:flex-row sm:items-center sm:justify-between">

        <!-- LEFT -->
        <div class="flex items-center gap-2 text-sm text-white/45">

          <span>
            Mostrando
          </span>

          <span
            id="paginationInfo"
            class="font-medium text-white/70"
          >
            0 - 0
          </span>

        </div>

        <!-- CONTROLS -->
        <div class="flex items-center gap-2">

          <button
            id="prevPage"
            class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.03] text-white/70 transition hover:bg-white/10 disabled:opacity-30"
          >

            <FiChevronLeft size={18} />

          </button>

          <div
            id="pageNumber"
            class="min-w-[70px] text-center text-sm text-white/60"
          >
            Página 1
          </div>

          <button
            id="nextPage"
            class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.03] text-white/70 transition hover:bg-white/10 disabled:opacity-30"
          >

            <FiChevronRight size={18} />

          </button>

        </div>

      </div>

    </div>

  </section>

</section>

<script>
  import "../../scripts/orders.ts";
</script>

</PortalLayout>