---
import PortalLayout from "../../layouts/PortalLayout.astro";
---

<PortalLayout title="Pedidos | AVYNA Saltillo">

<section class="space-y-8">

  <!-- HERO -->
  <section class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-gradient-to-br from-zinc-900 via-black to-zinc-950 p-6 sm:p-8">

    <div class="absolute -left-16 top-0 h-64 w-64 rounded-full bg-white/[0.03] blur-3xl"></div>
    <div class="absolute right-0 top-0 h-72 w-72 rounded-full bg-white/[0.02] blur-3xl"></div>

    <div class="relative z-10 flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">

      <div>

        <p class="text-xs uppercase tracking-[0.45em] text-white/30">
          Commercial Orders
        </p>

        <h1 class="mt-4 text-4xl font-semibold tracking-tight sm:text-5xl">
          Tus pedidos
        </h1>

        <p class="mt-4 max-w-2xl text-sm leading-7 text-white/55 sm:text-base">
          Consulta historial, saldos, estatus de entrega y actividad comercial.
        </p>

      </div>

      <div class="flex flex-wrap gap-3">

        <a
          href="/portal/new-order"
          class="inline-flex h-12 items-center justify-center rounded-2xl bg-white px-6 text-sm font-semibold text-black transition hover:scale-[1.02]"
        >
          Nuevo pedido
        </a>

        <button
          id="refreshOrders"
          class="inline-flex h-12 items-center justify-center rounded-2xl border border-white/10 px-6 text-sm text-white/80 transition hover:bg-white/10"
        >
          Actualizar
        </button>

      </div>

    </div>

  </section>

  <!-- FILTERS -->
  <section class="grid gap-4 lg:grid-cols-[1fr_220px_220px]">

    <div class="rounded-2xl border border-white/10 bg-white/[0.03] px-4">
      <input
        id="searchInput"
        type="text"
        placeholder="Buscar pedido..."
        class="h-14 w-full bg-transparent text-sm outline-none placeholder:text-white/35"
      />
    </div>

    <select
      id="statusFilter"
      class="h-14 rounded-2xl border border-white/10 bg-white/[0.03] px-4 text-sm outline-none"
    >
      <option value="">
        Todos los estatus
      </option>

      <option value="Pendiente">
        Pendiente
      </option>

      <option value="Proceso">
        En proceso
      </option>

      <option value="Enviado">
        Enviado
      </option>

      <option value="Entregado">
        Entregado
      </option>
    </select>

    <select
      id="sortFilter"
      class="h-14 rounded-2xl border border-white/10 bg-white/[0.03] px-4 text-sm outline-none"
    >
      <option value="recent">
        Más recientes
      </option>

      <option value="high">
        Mayor total
      </option>

      <option value="low">
        Menor total
      </option>
    </select>

  </section>

  <!-- KPIS -->
  <section class="grid gap-4 sm:grid-cols-3">

    <div class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6">
      <p class="text-xs uppercase tracking-[0.35em] text-white/35">
        Total pedidos
      </p>

      <p
        id="ordersTotal"
        class="mt-4 text-4xl font-semibold"
      >
        0
      </p>
    </div>

    <div class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6">
      <p class="text-xs uppercase tracking-[0.35em] text-white/35">
        Facturado
      </p>

      <p
        id="ordersAmount"
        class="mt-4 text-4xl font-semibold"
      >
        $0
      </p>
    </div>

    <div class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6">
      <p class="text-xs uppercase tracking-[0.35em] text-white/35">
        Pendiente
      </p>

      <p
        id="ordersBalance"
        class="mt-4 text-4xl font-semibold"
      >
        $0
      </p>
    </div>

  </section>

  <!-- TABLE -->
  <section class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-4 sm:p-6">

    <div class="overflow-x-auto">

      <table class="w-full min-w-[760px] text-left">

        <thead class="text-xs uppercase tracking-[0.28em] text-white/35">

          <tr class="border-b border-white/10">

            <th class="pb-4 font-medium">
              Pedido
            </th>

            <th class="pb-4 font-medium">
              Fecha
            </th>

            <th class="pb-4 font-medium">
              Estatus
            </th>

            <th class="pb-4 font-medium">
              Total
            </th>

            <th class="pb-4 font-medium">
              Saldo
            </th>

            <th class="pb-4 font-medium text-right">
              Acción
            </th>

          </tr>

        </thead>

        <tbody
          id="ordersTable"
          class="divide-y divide-white/10"
        >

          <tr>
            <td
              colspan="6"
              class="py-8 text-center text-white/45"
            >
              Cargando pedidos...
            </td>
          </tr>

        </tbody>

      </table>

    </div>

  </section>

</section>

<script>
  import "../../scripts/orders.ts";
</script>

</PortalLayout>