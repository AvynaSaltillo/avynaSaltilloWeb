---
import PortalLayout from "../../layouts/PortalLayout.astro";
---

<PortalLayout title="Pedidos | AVYNA Saltillo">

<section class="space-y-8">

  <!-- HERO -->
  <section class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-gradient-to-br from-zinc-900 via-black to-zinc-950 p-6 sm:p-8">

    <div class="absolute -left-16 top-0 h-64 w-64 rounded-full bg-white/[0.05] blur-3xl"></div>
    <div class="absolute right-0 top-0 h-72 w-72 rounded-full bg-white/[0.04] blur-3xl"></div>

    <div class="relative z-10 flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">

      <div>
        <p class="text-xs uppercase tracking-[0.45em] text-white/40">
          Commercial Orders
        </p>

        <h1 class="mt-4 text-4xl font-semibold tracking-tight sm:text-5xl">
          Tus pedidos
        </h1>

        <p class="mt-4 max-w-2xl text-sm leading-7 text-white/60 sm:text-base">
          Consulta historial, saldos, estatus de entrega y actividad comercial.
        </p>
      </div>

      <div class="flex flex-wrap gap-3">

        <a
          href="/portal/new-order"
          class="inline-flex h-12 items-center justify-center rounded-2xl bg-white px-6 text-sm font-semibold text-black transition hover:scale-[1.03]"
        >
          Nuevo pedido
        </a>

        <button
          id="refreshOrders"
          class="inline-flex h-12 items-center justify-center rounded-2xl border border-white/20 px-6 text-sm text-white/80 transition hover:bg-white/10"
        >
          Actualizar
        </button>

      </div>

    </div>

  </section>

  <!-- FILTERS -->
  <section class="grid gap-4 lg:grid-cols-[1fr_220px_220px]">

    <div class="rounded-2xl border border-white/20 bg-white/[0.05] px-4 transition focus-within:border-white/40 focus-within:ring-1 focus-within:ring-white/20">
      <input
        id="searchInput"
        type="text"
        placeholder="Buscar pedido..."
        class="h-14 w-full bg-transparent text-sm outline-none placeholder:text-white/40"
      />
    </div>

    <select class="h-14 rounded-2xl border border-white/20 bg-zinc-900 text-white px-4 text-sm outline-none focus:border-white/40 focus:ring-1 focus:ring-white/20">
      <option>Todos los estatus</option>
    </select>

    <select class="h-14 rounded-2xl border border-white/20 bg-zinc-900 text-white px-4 text-sm outline-none focus:border-white/40 focus:ring-1 focus:ring-white/20">
      <option>Más recientes</option>
    </select>

  </section>

  <!-- KPIS -->
  <section class="grid gap-4 sm:grid-cols-3">

    <div class="rounded-[2rem] border border-white/10 bg-white/[0.05] p-6">
      <p class="text-xs uppercase tracking-[0.35em] text-white/40">Total pedidos</p>
      <p class="mt-4 text-4xl font-semibold">0</p>
    </div>

    <div class="rounded-[2rem] border border-white/10 bg-white/[0.05] p-6">
      <p class="text-xs uppercase tracking-[0.35em] text-white/40">Facturado</p>
      <p class="mt-4 text-4xl font-semibold">$0</p>
    </div>

    <div class="rounded-[2rem] border border-white/10 bg-white/[0.05] p-6">
      <p class="text-xs uppercase tracking-[0.35em] text-white/40">Pendiente</p>
      <p class="mt-4 text-4xl font-semibold">$0</p>
    </div>

  </section>

  <!-- TABLE (FIX REAL) -->
<section>

  <div class="rounded-[2rem] border border-white/10 bg-white/[0.05] overflow-hidden">

    <div class="w-full overflow-x-auto">

      <table class="min-w-[720px] w-full text-left">

        <thead class="text-xs uppercase tracking-[0.28em] text-white/60">
          <tr class="border-b border-white/10">
            <th class="px-4 py-4">Pedido</th>
            <th class="px-4 py-4">Fecha</th>
            <th class="px-4 py-4">Estatus</th>
            <th class="px-4 py-4">Total</th>
            <th class="px-4 py-4">Saldo</th>
            <th class="px-4 py-4 text-right">Acción</th>
          </tr>
        </thead>

        <tbody>
          <tr>
            <td colspan="6" class="py-12 text-center text-white/50 text-sm">
              No tienes pedidos aún.
            </td>
          </tr>
        </tbody>

      </table>

    </div>

  </div>

</section>

</section>

<script>
  import "../../scripts/orders.ts";
</script>

</PortalLayout>