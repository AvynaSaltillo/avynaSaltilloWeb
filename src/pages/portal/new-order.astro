---
import PortalLayout from "../../layouts/PortalLayout.astro";
import { products } from "../../data/products";

import { FiShoppingCart, FiTrash2 } from "react-icons/fi";
import { FaGift } from "react-icons/fa6";
import { HiOutlineXMark } from "react-icons/hi2";

---

<PortalLayout title="Nuevo Pedido | AVYNA">

<section class="space-y-6 pb-35 lg:pb-0">

<!-- HERO -->
<section class="rounded-[2rem] border border-white/10 bg-gradient-to-br from-white/[0.05] via-white/[0.02] to-transparent p-6 lg:p-7">
<div class="flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">

<div>
<p class="text-xs uppercase tracking-[0.42em] text-white/35">
Private Client Portal
</p>

<h1 class="mt-3 text-4xl lg:text-5xl font-semibold tracking-tight">
Nuevo pedido
</h1>

<p class="mt-3 max-w-2xl text-sm leading-7 text-white/55">
Compra profesional con precios distribuidor. Agrega productos rápido y envía pedido directo.
</p>
</div>

<div class="grid gap-3 sm:grid-cols-3">
<div class="rounded-2xl border border-white/10 bg-white/[0.03] px-5 py-4">
<p class="text-[10px] uppercase tracking-[0.28em] text-white/35">Productos disponibles</p>
<p class="mt-2 text-2xl font-semibold">{products.length}</p>
</div>

<div class="rounded-2xl border border-white/10 bg-white/[0.03] px-5 py-4">
<p class="text-[10px] uppercase tracking-[0.28em] text-white/35">Pedido mínimo (precio salón)</p>
<p class="mt-2 text-2xl font-semibold">$1,500</p>
</div>

<div class="rounded-2xl border border-white/10 bg-white/[0.03] px-5 py-4">
<p class="text-[10px] uppercase tracking-[0.28em] text-white/35">Canal</p>
<p class="mt-2 text-2xl font-semibold">WhatsApp</p>
</div>
</div>

</div>
</section>

<!-- GRID -->
<section class="grid gap-5 xl:grid-cols-[minmax(0,1fr)_360px] 2xl:grid-cols-[minmax(0,1fr)_390px]">

<!-- LEFT -->
<div class="space-y-5">

<!-- FILTERS -->
<section class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-5">

<div class="grid gap-3 lg:grid-cols-[1fr_280px]">

<input
id="searchInput"
type="text"
placeholder="Buscar producto..."
class="h-12 rounded-2xl border border-white/10 bg-black/40 px-4 text-sm outline-none placeholder:text-white/30"
/>

<select
id="familyFilter"
class="h-12 rounded-2xl border border-white/10 bg-black/40 px-4 text-sm outline-none"
>
<option value="">Todas las líneas</option>
</select>

</div>
</section>

<!-- PRODUCTS -->
<!-- TABLE -->
<section class="rounded-[2rem] border border-white/10 bg-white/[0.03] overflow-hidden">

<div class="hidden lg:grid grid-cols-[minmax(0,1fr)_110px_130px_210px] gap-3 border-b border-white/10 px-6 py-4 text-[11px] uppercase tracking-[0.25em] text-white/35">
  <div>Producto</div>
  <div>Línea</div>
  <div>Precio salón</div>
  <div class="text-right pr-14">Cantidad</div>
</div>

<div id="productsGrid" class="divide-y divide-white/5"></div>
<!-- FOOT (PAGINACIÓN) -->
<div class="border-t border-white/10 px-4 py-4">

  <div class="flex flex-col gap-3">

    <!-- TOP -->
    <div class="flex items-center justify-between">

      <div class="flex items-center gap-2">
        <span class="text-sm text-white/45">Mostrando</span>

        <select
  id="limitSelect"
  class="h-9 rounded-xl border border-white/10 bg-zinc-900 text-white px-3 text-sm outline-none appearance-none"
>
  <option value="10" class="bg-zinc-900 text-white">10</option>
  <option value="20" class="bg-zinc-900 text-white">20</option>
  <option value="50" class="bg-zinc-900 text-white">50</option>
  <option value="100" class="bg-zinc-900 text-white">100</option>
</select>

<span class="text-sm text-white/45">productos</span>
      </div>

    </div>

    <!-- PAGINATION -->
    <div class="flex items-center justify-center gap-3">

      <button id="prevPage"
        class="h-10 w-10 grid place-items-center rounded-xl border border-white/10 bg-white/[0.03] active:scale-95 transition">
        ←
      </button>

      <div id="pageInfo"
        class="text-sm text-white/70 min-w-[60px] text-center">
        1 / 1
      </div>

      <button id="nextPage"
        class="h-10 w-10 grid place-items-center rounded-xl border border-white/10 bg-white/[0.03] active:scale-95 transition">
        →
      </button>

    </div>

  </div>

</div>

</section>

</div>

<!-- RIGHT DESKTOP -->
<aside class="hidden xl:block xl:sticky xl:top-5 h-fit">
<section class="rounded-4xl border border-white/10 bg-zinc-950/90 p-5">

<div class="flex items-center justify-between">
<h2 class="text-[18px] font-semibold">Carrito</h2>
<span id="cartCount" class="rounded-full border border-white/10 px-2.5 py-1 text-[11px] text-white/55">
Sin artículos
</span>
</div>

<div id="cartItems" class="mt-4 space-y-2 max-h-[32vh] overflow-y-auto pr-1"></div>

<div class="mt-5 border-t border-white/10 pt-5 space-y-3 text-sm">
<div class="flex justify-between text-[13px] text-white/45">
<span>Subtotal público</span>
<span id="publicTotal">$0</span>
</div>

<div class="flex justify-between text-[13px] text-white/45">
<span>Ganancia (Descuento)</span>
<span id="savingTotal" class="text-green-400">$0</span>
</div>

<div class="transition-all duration-300 ease-out flex justify-between items-end text-white font-semibold text-[20px]">
  <span>Total salón</span>
  <span id="finalTotal" class="transition-all duration-300 font-bold">$0</span>
</div>
</div>

<div class="sticky bottom-0 left-0 right-0 mt-3 pt-4 bg-gradient-to-t from-black/80 to-transparent space-y-2">

  <div id="desktopMinText" class="text-sm text-white/60">
    Agrega $1,500 para completar pedido mínimo
  </div>

  <div class="h-2 w-full rounded-full bg-white/10 overflow-hidden">
    <div id="desktopProgress"
      class="h-full w-0 bg-white/40 transition-all duration-500">
    </div>
  </div>

</div>

<div class="mt-5 rounded-3xl border border-white/15 bg-white/[0.04] backdrop-blur-xl px-4 py-4">

  <p class="text-[10px] uppercase tracking-[0.25em] text-white/30">
    Condición de crédito
  </p>

  <p id="creditTitle"
class="mt-1 text-[15px] font-semibold text-white flex items-center gap-2">

  <span id="creditTitleText" class="font-bold">Contado total</span>

  <span id="creditGiftIcon" class="hidden">
    <FaGift size={22} />
  </span>

</p>

  <p id="creditText" class="text-[13px] text-white/40">
    Pedido menor a $1,500
  </p>

</div>

<div class="mt-4 grid gap-2">
<button id="clearBtn" class="h-11 rounded-2xl border border-white/10 bg-white/[0.03] text-sm">
Vaciar carrito
</button>

<button id="sendBtn" class="h-11 rounded-2xl bg-white text-sm font-semibold text-black">
Enviar pedido
</button>
</div>

</section>
</aside>

</section>
</section>

<!-- ========================= -->
<!-- 🔥 MOBILE STICKY -->
<!-- ========================= -->

<div id="mobileCartBar"
class="xl:hidden fixed bottom-0 left-0 right-0 z-30 px-4 pb-3">

<div
class="mx-auto max-w-[500px] rounded-2xl bg-white/[0.06] border border-white/15 backdrop-blur-3xl p-4 shadow-[0_20px_60px_rgba(0,0,0,0.6)] transition-all duration-500">

<div id="mobileCartTrigger"
class="grid grid-cols-[1fr_auto] items-center gap-3 cursor-pointer py-5 active:scale-[0.98] transition">

<!-- LEFT -->
<div class="flex flex-col gap-1 min-w-0">

<div class="flex items-center gap-2 text-[16px] text-white/80 truncate">
<FiShoppingCart size={22}/>
<span id="mobileItems">Sin artículos</span>
</div>

<span class="text-xl font-semibold text-white">
Total salón: <span id="mobileTotal">$0</span>
</span>

</div>

<!-- RIGHT -->
<div class="flex items-center gap-2">

<button id="mobileClearBtn"
class="hidden text-xs text-red-400">
<FiTrash2 size={16}/>
</button>

<button id="mobileOpenModal"
class="h-9 px-4 rounded-xl bg-white text-black text-sm font-semibold active:scale-95 transition">
Ver pedido
</button>

</div>

</div>
</div>
</div>

<!-- ========================= -->
<!-- 🔥 MODAL -->
<!-- ========================= -->

<div id="cartModal" class="fixed inset-0 z-50 hidden">

<div id="modalBackdrop"
class="absolute inset-0 bg-black/0 transition duration-300"></div>

<div id="modalPanel"
class="absolute inset-x-0 bottom-0 translate-y-full transition-transform duration-300 ease-out bg-[#0c0c0f]/95 backdrop-blur-xl rounded-t-3xl p-5 max-h-[92vh] pb-6 overflow-y-auto shadow-[0_-20px_80px_rgba(0,0,0,0.8)]">

<div class="flex items-center justify-between mb-4">

  <div class="flex flex-col">
    <h2 class="text-[18px] font-semibold text-white">Carrito</h2>

    <span class="text-xs text-white/40">
      <span id="modalItems">Sin artículos</span>
    </span>
  </div>

  <button id="closeModal"
    class="h-9 w-9 rounded-xl border border-white/10 grid place-items-center text-white/60 active:scale-90 transition">
    <HiOutlineXMark size={18}/>
  </button>

</div>

<div id="modalCartContent" class="space-y-3 max-h-80 overflow-y-auto"></div>

<div class="mt-4 border-t border-white/10 pt-4 space-y-2 text-sm">

  <div class="flex justify-between text-white/40">
    <span>Subtotal público</span>
    <span id="modalPublic">$0</span>
  </div>

  <!-- 🔥 NUEVO -->
  <div class="flex justify-between text-white/40">
    <span>Ganancia (Descuento)</span>
    <span id="modalSaving" class="text-green-400">$0</span>
  </div>

  <div class="transition-all duration-300 ease-out flex justify-between text-white font-semibold text-[20px]">
    <span>Total salón</span>
    <span id="modalTotal" class="transition-all duration-300">$0</span>
  </div>

</div>

<div class="mt-5 space-y-3">

  <div id="modalMinText" class="text-sm text-white/60">
    Agrega $1,500 para completar pedido mínimo
  </div>

  <div class="h-2 w-full rounded-full bg-white/10 overflow-hidden">
    <div id="modalProgress"
      class="h-full w-0 bg-white/40 transition-all duration-500">
    </div>
  </div>

</div>


<div class="mt-5 rounded-3xl border border-white/15 bg-white/[0.04] backdrop-blur-xl px-4 py-4">

  <p class="text-[10px] uppercase tracking-[0.25em] text-white/30">
    Condición de crédito
  </p>

    <p id="modalCreditTitle"
class="mt-1 text-[15px] font-semibold text-white flex items-center gap-2">

  <span id="modalCreditTitleText" class="font-bold">Contado total</span>

  <span id="modalCreditGiftIcon" class="hidden">
    <FaGift size={22} />
  </span>

</p>

  <p id="modalCreditText" class="text-[13px] text-white/40">
    Pedido menor a $1,500
  </p>

</div>

<div class="sticky bottom-0 left-0 right-0 mt-6 pt-4 bg-gradient-to-t from-black/80 to-transparent space-y-2">
<button id="modalClearBtn"
class="w-full h-12 rounded-2xl border border-white/15 text-white/70 active:scale-95 transition">
Limpiar
</button>

<button id="modalSendBtn"
class="w-full h-12 rounded-2xl bg-white text-black font-semibold active:scale-95 transition">
Enviar pedido
</button>
</div>

</div>
</div>

<script define:vars={{ products }}>
window.__PRODUCTS__ = products;
</script>

<script>
import "../../scripts/new-order.ts";

/* 🔥 ANIMACIÓN ENTRADA STICKY */
const bar = document.getElementById("mobileCartBar");

if (bar) {
bar.classList.add("translate-y-10", "opacity-0");

setTimeout(() => {
bar.classList.remove("translate-y-10", "opacity-0");
}, 120);
}
</script>

</PortalLayout>