---
import PortalLayout from "../../layouts/PortalLayout.astro";
import "../../scripts/dashboard.ts";
---

<PortalLayout title="Dashboard AVYNA">

<section class="space-y-8">

  <!-- HERO -->
  <section class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-gradient-to-br from-zinc-900 via-black to-zinc-950 p-6 sm:p-8 xl:p-10">

    <!-- GLOWS -->
    <div class="absolute -left-20 top-0 h-72 w-72 rounded-full bg-white/[0.03] blur-3xl"></div>
    <div class="absolute right-0 top-0 h-80 w-80 rounded-full bg-white/[0.02] blur-3xl"></div>
    <div class="absolute bottom-0 left-1/3 h-72 w-72 rounded-full bg-white/[0.02] blur-3xl"></div>

    <div class="relative z-10 grid gap-8 xl:grid-cols-[1.4fr_.8fr]">

      <!-- LEFT -->
      <div>

        <p class="text-xs uppercase tracking-[0.45em] text-white/30">
          Private Client Portal
        </p>

        <h1
          id="welcomeName"
          class="mt-5 text-4xl font-semibold tracking-tight sm:text-5xl xl:text-6xl"
        >
          Bienvenido
        </h1>

        <p class="mt-5 max-w-2xl text-sm leading-7 text-white/55 sm:text-base">
          Gestiona pedidos, historial comercial, promociones privadas y acceso exclusivo AVYNA Saltillo.
        </p>

        <!-- ACTIONS -->
        <div class="mt-8 flex flex-wrap gap-3">

          <a
            href="/portal/orders"
            class="inline-flex h-12 items-center justify-center rounded-2xl bg-white px-6 text-sm font-semibold text-black transition hover:scale-[1.02]"
          >
            Nuevo pedido
          </a>

          <a
            href="/grow"
            class="inline-flex h-12 items-center justify-center rounded-2xl border border-white/10 px-6 text-sm font-medium text-white/80 transition hover:bg-white/10"
          >
            Catálogo
          </a>

          <a
            href="https://wa.me/528441234567"
            target="_blank"
            class="inline-flex h-12 items-center justify-center rounded-2xl border border-white/10 px-6 text-sm font-medium text-white/80 transition hover:bg-white/10"
          >
            Soporte
          </a>

        </div>

      </div>

      <!-- RIGHT -->
      <div class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6 backdrop-blur-xl">

        <p class="text-xs uppercase tracking-[0.45em] text-white/30">
          Cierre semanal
        </p>

        <div class="mt-4 flex items-center justify-between gap-3">

          <h2 class="text-xl font-semibold">
            Jueves 11:59 PM
          </h2>

          <span
            id="weeklyBadge"
            class="rounded-full border border-white/10 px-4 py-2 text-xs text-white/70"
          >
            Cargando...
          </span>

        </div>

        <p
          id="countdown"
          class="mt-6 text-5xl font-semibold tracking-tight"
        >
          00:00:00
        </p>

        <p
          id="cutoffStatus"
          class="mt-4 text-sm text-white/45"
        >
          Calculando...
        </p>

      </div>

    </div>

  </section>

  <!-- KPI GRID -->
  <section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">

    <div class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6">
      <p class="text-xs uppercase tracking-[0.35em] text-white/35">
        Este mes
      </p>
      <p
        id="monthTotal"
        class="mt-4 text-4xl font-semibold"
      >
        $0
      </p>
    </div>

    <div class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6">
      <p class="text-xs uppercase tracking-[0.35em] text-white/35">
        Pedidos
      </p>
      <p
        id="ordersCount"
        class="mt-4 text-4xl font-semibold"
      >
        0
      </p>
    </div>

    <div class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6">
      <p class="text-xs uppercase tracking-[0.35em] text-white/35">
        Pendiente
      </p>
      <p
        id="pendingBalance"
        class="mt-4 text-4xl font-semibold"
      >
        $0
      </p>
    </div>

    <div class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6">
      <p class="text-xs uppercase tracking-[0.35em] text-white/35">
        Próximo pago
      </p>
      <p
        id="nextDue"
        class="mt-4 text-2xl font-semibold"
      >
        Sin saldo
      </p>
    </div>

  </section>

  <!-- LOWER GRID -->
  <section class="grid gap-6 xl:grid-cols-[1.25fr_.75fr]">

    <!-- ORDERS -->
    <section class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6">

      <div class="flex items-center justify-between gap-3">

        <h2 class="text-2xl font-semibold">
          Pedidos recientes
        </h2>

        <a
          href="/portal/orders"
          class="text-sm text-white/45 hover:text-white"
        >
          Ver todos
        </a>

      </div>

      <div
        id="ordersList"
        class="mt-6 space-y-3"
      >

        <div class="rounded-2xl border border-white/10 bg-black/30 p-4 text-white/45">
          Cargando pedidos...
        </div>

      </div>

    </section>

    <!-- TERMS -->
    <section class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6">

      <p class="text-xs uppercase tracking-[0.4em] text-white/30">
        Condiciones comerciales
      </p>

      <div class="mt-6 space-y-3">

        <div class="rounded-2xl border border-white/10 bg-black/30 p-4">
          <p class="font-semibold">$0 - $1,499</p>
          <p class="mt-1 text-sm text-white/45">
            Pago de contado total.
          </p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-black/30 p-4">
          <p class="font-semibold">$1,500 - $9,999</p>
          <p class="mt-1 text-sm text-white/45">
            50% entrega + 50% a 15 días.
          </p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-black/30 p-4">
          <p class="font-semibold">$10,000+</p>
          <p class="mt-1 text-sm text-white/45">
            50% entrega + 50% a 30 días.
          </p>
        </div>

      </div>

    </section>

  </section>

</section>

<script type="module" src="/src/scripts/dashboard.ts"></script>

</PortalLayout>