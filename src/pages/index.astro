---
// src/pages/index.astro

import Layout from "../layouts/PublicLayout.astro";

/* SHARED */
import Navbar from "../components/shared/Navbar.astro";
import Footer from "../components/shared/Footer.astro";

/* PUBLIC */
import Hero from "../components/public/Hero.astro";
import Benefits from "../components/public/Benefits.astro";
import DiagnosticBasic from "../components/public/DiagnosticBasic.astro";
import SalonMap from "../components/public/SalonMap.astro";
import FAQ from "../components/public/FAQ.astro";

import { ArrowRight, Sparkles, Store } from "lucide-react";
---

<Layout
  title="AVYNA Saltillo | Belleza Profesional para tu Cabello"
  description="Descubre productos profesionales AVYNA, diagnóstico capilar, catálogo premium y salones autorizados."
>

  <!-- NAVBAR -->
  <Navbar />

  <!-- PAGE -->
  <main class="overflow-hidden bg-black text-white">

    <!-- HERO -->
    <Hero />

    <!-- BENEFITS -->
    <section id="beneficios" class="relative reveal">
      <Benefits />
    </section>

    <!-- DIAGNÓSTICO -->
    <section id="diagnostico" class="relative reveal">
      <DiagnosticBasic />
    </section>

    <!-- MAPA -->
    <section id="salones" class="relative reveal">
      <SalonMap />
    </section>

    <!-- FAQ -->
    <section id="faq" class="relative reveal">
      <FAQ />
    </section>

    <!-- PARTNERS CARD -->
    <section id="partners" class="relative px-6 pb-10">

      <div class="mx-auto max-w-6xl">

        <div class="reveal relative overflow-hidden rounded-[2.5rem] border border-white/10 bg-white/3 p-8 backdrop-blur-2xl md:p-12">

          <!-- glow -->
          <div class="absolute inset-0 -z-10">
            <div class="absolute right-0 top-0 h-60 w-60 rounded-full bg-white/5 blur-3xl"></div>
          </div>

          <div class="grid items-center gap-10 lg:grid-cols-2">

            <!-- LEFT -->
            <div>

              <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-5 py-2 text-sm text-white/75">
                <Store size={15} />
                Partners AVYNA
              </div>

              <h2 class="mt-6 text-4xl font-bold leading-tight tracking-tight md:text-5xl">
                ¿Tienes salón o negocio?
                <span class="block text-zinc-400">
                  Vende AVYNA con nosotros
                </span>
              </h2>

              <p class="mt-5 max-w-xl text-lg leading-relaxed text-white/60">
                Obtén acceso a precios especiales, productos premium y atención personalizada
                para impulsar tus ventas en Saltillo.
              </p>

              <div class="mt-8 flex flex-col gap-4 sm:flex-row">

                <a
                  href="/partners/login"
                  class="press inline-flex h-14 items-center justify-center gap-2 rounded-full bg-white px-8 font-semibold text-black transition duration-300 hover:scale-105"
                >
                  Tengo salón
                  <ArrowRight size={18} />
                </a>

                <a
                  href="/partners/login"
                  class="press inline-flex h-14 items-center justify-center rounded-full border border-white/10 bg-white/5 px-8 transition duration-300 hover:bg-white hover:text-black"
                >
                  Quiero vender AVYNA
                </a>

              </div>

            </div>

            <!-- RIGHT -->
            <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">

              <div class="rounded-3xl border border-white/10 bg-white/3 px-6 py-5">
                <p class="text-2xl font-bold">Mayorista</p>
                <p class="mt-1 text-sm text-white/45">
                  Precios exclusivos
                </p>
              </div>

              <div class="rounded-3xl border border-white/10 bg-white/3 px-6 py-5">
                <p class="text-2xl font-bold">Top</p>
                <p class="mt-1 text-sm text-white/45">
                  Productos en tendencia
                </p>
              </div>

              <div class="rounded-3xl border border-white/10 bg-white/3 px-6 py-5">
                <p class="text-2xl font-bold">Local</p>
                <p class="mt-1 text-sm text-white/45">
                  Soporte rápido Saltillo
                </p>
              </div>

            </div>

          </div>

        </div>

      </div>

    </section>

  </main>

  <!-- FOOTER -->
  <Footer />

</Layout>